@inject IJSRuntime JsRuntime
@inject ToastState ToastState

<AppButton Variant="@ButtonVariant"
           Size="@ButtonSize"
           Class="@ButtonClass"
           OnClick="OpenAsync">
    @ButtonLabel
</AppButton>

<AppModal IsOpen="@IsOpen"
          Title="@ModalTitle"
          Description="@ModalDescription"
          OnClose="CloseAsync">
    <ChildContent>
        <div class="space-y-5">
            @if (!string.IsNullOrWhiteSpace(InlineErrorMessage))
            {
                <div class="soft-block border border-red-200/70 p-4 text-sm text-red-700">
                    @InlineErrorMessage
                </div>
            }

            @if (UsageSteps.Count > 0 || !string.IsNullOrWhiteSpace(CopyablePrompt))
            {
                <div class="soft-block space-y-3 p-4">
                    <div class="space-y-1">
                        @if (!string.IsNullOrWhiteSpace(CopyablePrompt))
                        {
                            <p class="text-sm font-semibold text-text">@ResolvedCopyablePromptTitle</p>
                            <p class="text-sm leading-7 text-muted">@ResolvedCopyablePromptDescription</p>
                        }
                        else
                        {
                            <p class="text-sm font-semibold text-text">@L["How to use it"]</p>
                            <p class="text-sm leading-7 text-muted">@L["Prepare the markdown first, then paste it here."]</p>
                        }

                        @if (!string.IsNullOrWhiteSpace(CopyablePrompt))
                        {
                            <p class="text-xs leading-6 text-muted">@L["The full message will be copied to your clipboard."]</p>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(PromptPrimaryToken) || !string.IsNullOrWhiteSpace(PromptSecondaryToken))
                    {
                        <div class="space-y-3">
                            @if (!string.IsNullOrWhiteSpace(PromptPrimaryToken))
                            {
                                <div class="app-field space-y-2">
                                    <label class="app-field-label" for="@($"{FieldPrefix}-prompt-primary")">@ResolvedPromptPrimaryLabel</label>

                                    <div class="flex items-center gap-3">
                                        <input id="@($"{FieldPrefix}-prompt-primary")"
                                               type="text"
                                               class="app-input flex-1"
                                               value="@PrimaryPromptValue"
                                               placeholder="@PromptPrimaryPlaceholder"
                                               @oninput="HandlePrimaryPromptInput" />

                                        @if (!string.IsNullOrWhiteSpace(CopyablePrompt))
                                        {
                                            <AppButton Variant="secondary"
                                                       Size="sm"
                                                       Disabled="@IsBusy"
                                                       OnClick="CopyPromptAsync">
                                                @L["Copy Message"]
                                            </AppButton>
                                        }
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(PromptPrimaryHelpText))
                                    {
                                        <p class="app-field-help">@PromptPrimaryHelpText</p>
                                    }
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(PromptSecondaryToken))
                            {
                                <AppInput Id="@($"{FieldPrefix}-prompt-secondary")"
                                          Label="@ResolvedPromptSecondaryLabel"
                                          Value="@SecondaryPromptValue"
                                          ValueChanged="HandleSecondaryPromptChanged"
                                          Placeholder="@PromptSecondaryPlaceholder"
                                          HelpText="@PromptSecondaryHelpText" />
                            }
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(CopyablePrompt))
                    {
                        <div class="flex justify-start lg:justify-end">
                            <AppButton Variant="secondary"
                                       Size="sm"
                                       style="border-radius: 1rem; white-space: nowrap;"
                                       Disabled="@IsBusy"
                                       OnClick="CopyPromptAsync">
                                @L["Copy Message"]
                            </AppButton>
                        </div>
                    }

                    @if (UsageSteps.Count > 0)
                    {
                        <ol class="space-y-2 text-sm leading-7 text-muted">
                            @for (var index = 0; index < UsageSteps.Count; index++)
                            {
                                <li><span class="font-semibold text-text">@(index + 1).</span> @UsageSteps[index]</li>
                            }
                        </ol>
                    }
                </div>
            }

            <AppTextarea Id="@($"{FieldPrefix}-markdown")"
                         Label="@ResolvedTextareaLabel"
                         Value="@MarkdownText"
                         ValueChanged="HandleMarkdownChanged"
                         Placeholder="@Placeholder"
                         HelpText="@ResolvedHelpText"
                         TextareaClassName="font-mono text-xs leading-6"
                         style="min-height: 14rem;" />

        </div>
    </ChildContent>
    <Footer>
        <AppButton Variant="secondary" Disabled="@IsBusy" OnClick="CloseButtonAsync">@L["Cancel"]</AppButton>
        <AppButton IsLoading="@IsBusy" OnClick="HandleConfirmAsync">@ResolvedConfirmLabel</AppButton>
    </Footer>
</AppModal>

@code {
    private bool IsOpen { get; set; }
    private bool IsBusy { get; set; }
    private string MarkdownText { get; set; } = string.Empty;
    private string? InlineErrorMessage { get; set; }
    private string PrimaryPromptValue { get; set; } = string.Empty;
    private string SecondaryPromptValue { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string ButtonLabel { get; set; } = default!;

    [Parameter, EditorRequired]
    public string ModalTitle { get; set; } = default!;

    [Parameter, EditorRequired]
    public string ModalDescription { get; set; } = default!;

    [Parameter]
    public string TextareaLabel { get; set; } = string.Empty;

    [Parameter]
    public string HelpText { get; set; } = string.Empty;

    [Parameter]
    public string Placeholder { get; set; } = string.Empty;

    [Parameter]
    public string ExampleMarkdown { get; set; } = string.Empty;

    [Parameter]
    public string ExampleTitle { get; set; } = string.Empty;

    [Parameter]
    public IReadOnlyList<string> UsageSteps { get; set; } = [];

    [Parameter]
    public string CopyablePrompt { get; set; } = string.Empty;

    [Parameter]
    public string CopyablePromptTitle { get; set; } = string.Empty;

    [Parameter]
    public string CopyablePromptDescription { get; set; } = string.Empty;

    [Parameter]
    public string? PromptPrimaryToken { get; set; }

    [Parameter]
    public string PromptPrimaryLabel { get; set; } = string.Empty;

    [Parameter]
    public string PromptPrimaryPlaceholder { get; set; } = string.Empty;

    [Parameter]
    public string? PromptPrimaryHelpText { get; set; }

    [Parameter]
    public string? PromptPrimaryValue { get; set; }

    [Parameter]
    public string? PromptSecondaryToken { get; set; }

    [Parameter]
    public string PromptSecondaryLabel { get; set; } = string.Empty;

    [Parameter]
    public string PromptSecondaryPlaceholder { get; set; } = string.Empty;

    [Parameter]
    public string? PromptSecondaryHelpText { get; set; }

    [Parameter]
    public string? PromptSecondaryValue { get; set; }

    [Parameter]
    public string ConfirmLabel { get; set; } = string.Empty;

    [Parameter]
    public string ButtonVariant { get; set; } = "secondary";

    [Parameter]
    public string ButtonSize { get; set; } = "md";

    [Parameter]
    public string? ButtonClass { get; set; }

    [Parameter]
    public string FieldPrefix { get; set; } = "markdown-import";

    [Parameter, EditorRequired]
    public Func<string, Task<MarkdownImportApplyResult>> OnConfirmAsync { get; set; } = default!;

    private string ResolvedTextareaLabel => string.IsNullOrWhiteSpace(TextareaLabel) ? L["Markdown"] : TextareaLabel;
    private string ResolvedHelpText => string.IsNullOrWhiteSpace(HelpText) ? L["Paste the markdown here when it's ready."] : HelpText;
    private string ResolvedCopyablePromptTitle => string.IsNullOrWhiteSpace(CopyablePromptTitle) ? L["Message for your assistant"] : CopyablePromptTitle;
    private string ResolvedCopyablePromptDescription => string.IsNullOrWhiteSpace(CopyablePromptDescription) ? L["Copy this message into ChatGPT or another assistant, then paste the result back here."] : CopyablePromptDescription;
    private string ResolvedPromptPrimaryLabel => string.IsNullOrWhiteSpace(PromptPrimaryLabel) ? L["Title"] : PromptPrimaryLabel;
    private string ResolvedPromptSecondaryLabel => string.IsNullOrWhiteSpace(PromptSecondaryLabel) ? L["Additional details"] : PromptSecondaryLabel;
    private string ResolvedConfirmLabel => string.IsNullOrWhiteSpace(ConfirmLabel) ? L["Apply Markdown"] : ConfirmLabel;

    private Task OpenAsync(MouseEventArgs _)
    {
        InlineErrorMessage = null;
        PrimaryPromptValue = PromptPrimaryValue ?? string.Empty;
        SecondaryPromptValue = PromptSecondaryValue ?? string.Empty;
        IsOpen = true;
        return Task.CompletedTask;
    }

    private Task CloseButtonAsync(MouseEventArgs _)
        => CloseAsync();

    private Task CloseAsync()
    {
        if (IsBusy)
        {
            return Task.CompletedTask;
        }

        IsOpen = false;
        InlineErrorMessage = null;
        return Task.CompletedTask;
    }

    private Task HandleMarkdownChanged(string? value)
    {
        MarkdownText = value ?? string.Empty;
        InlineErrorMessage = null;
        return Task.CompletedTask;
    }

    private Task HandlePrimaryPromptChanged(string? value)
    {
        PrimaryPromptValue = value ?? string.Empty;
        InlineErrorMessage = null;
        return Task.CompletedTask;
    }

    private Task HandlePrimaryPromptInput(ChangeEventArgs args)
        => HandlePrimaryPromptChanged(args.Value?.ToString());

    private Task HandleSecondaryPromptChanged(string? value)
    {
        SecondaryPromptValue = value ?? string.Empty;
        InlineErrorMessage = null;
        return Task.CompletedTask;
    }

    private async Task CopyPromptAsync(MouseEventArgs _)
    {
        if (string.IsNullOrWhiteSpace(CopyablePrompt))
        {
            return;
        }

        try
        {
            await JsRuntime.InvokeVoidAsync("watchAtlasStorage.copyText", BuildPrompt());
            ToastState.ShowSuccess(L["Message copied."], L["Paste it into your assistant to get the markdown."]);
        }
        catch (Exception exception)
        {
            InlineErrorMessage = L.Format("The message could not be copied: {0}", exception.Message);
        }
    }

    private async Task HandleConfirmAsync(MouseEventArgs _)
    {
        if (string.IsNullOrWhiteSpace(MarkdownText))
        {
            InlineErrorMessage = L["Paste markdown first."];
            return;
        }

        try
        {
            IsBusy = true;
            InlineErrorMessage = null;

            var result = await OnConfirmAsync.Invoke(MarkdownText);
            if (result.IsSuccess)
            {
                MarkdownText = string.Empty;
                IsOpen = false;
                return;
            }

            InlineErrorMessage = result.ErrorMessage ?? L["The markdown could not be applied."];
        }
        finally
        {
            IsBusy = false;
        }
    }

    private string BuildPrompt()
    {
        var prompt = CopyablePrompt;

        if (!string.IsNullOrWhiteSpace(PromptPrimaryToken))
        {
            prompt = prompt.Replace(PromptPrimaryToken, string.IsNullOrWhiteSpace(PrimaryPromptValue) ? PromptPrimaryToken : PrimaryPromptValue, StringComparison.Ordinal);
        }

        if (!string.IsNullOrWhiteSpace(PromptSecondaryToken))
        {
            prompt = prompt.Replace(PromptSecondaryToken, string.IsNullOrWhiteSpace(SecondaryPromptValue) ? PromptSecondaryToken : SecondaryPromptValue, StringComparison.Ordinal);
        }

        return prompt;
    }
}
