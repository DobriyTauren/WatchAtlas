@inject IJSRuntime JsRuntime
@inject ToastState ToastState

<AppButton Variant="@ButtonVariant"
           Size="@ButtonSize"
           Class="@ButtonClass"
           OnClick="OpenAsync">
    @ButtonLabel
</AppButton>

<AppModal IsOpen="@IsOpen"
          Title="@ModalTitle"
          Description="@ModalDescription"
          OnClose="CloseAsync">
    <ChildContent>
        <div class="space-y-5">
            @if (!string.IsNullOrWhiteSpace(InlineErrorMessage))
            {
                <div class="soft-block border border-red-200/70 p-4 text-sm text-red-700">
                    @InlineErrorMessage
                </div>
            }

            @if (UsageSteps.Count > 0 || !string.IsNullOrWhiteSpace(CopyablePrompt))
            {
                <div class="soft-block space-y-3 p-4">
                    <div class="flex flex-wrap items-start justify-between gap-3">
                        <div class="space-y-1">
                            @if (!string.IsNullOrWhiteSpace(CopyablePrompt))
                            {
                                <p class="text-sm font-semibold text-text">@CopyablePromptTitle</p>
                                <p class="text-sm leading-7 text-muted">@CopyablePromptDescription</p>
                            }
                            else
                            {
                                <p class="text-sm font-semibold text-text">How to use it</p>
                                <p class="text-sm leading-7 text-muted">Generate clean markdown first, then paste it here or upload a file.</p>
                            }

                            @if (!string.IsNullOrWhiteSpace(CopyablePrompt))
                            {
                                <p class="text-xs leading-6 text-muted">The full prompt will be copied to your clipboard.</p>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(CopyablePrompt))
                        {
                            <AppButton Variant="secondary"
                                       Size="sm"
                                       Disabled="@IsBusy"
                                       OnClick="CopyPromptAsync">
                                Copy Prompt
                            </AppButton>
                        }
                    </div>

                    @if (UsageSteps.Count > 0)
                    {
                        <ol class="space-y-2 text-sm leading-7 text-muted">
                            @for (var index = 0; index < UsageSteps.Count; index++)
                            {
                                <li><span class="font-semibold text-text">@(index + 1).</span> @UsageSteps[index]</li>
                            }
                        </ol>
                    }
                </div>
            }

            <AppTextarea Id="@($"{FieldPrefix}-markdown")"
                         Label="@TextareaLabel"
                         Value="@MarkdownText"
                         ValueChanged="HandleMarkdownChanged"
                         Placeholder="@Placeholder"
                         HelpText="@HelpText"
                         TextareaClassName="font-mono text-xs leading-6"
                         style="min-height: 14rem;" />

        </div>
    </ChildContent>
    <Footer>
        <AppButton Variant="secondary" Disabled="@IsBusy" OnClick="CloseButtonAsync">Cancel</AppButton>
        <AppButton IsLoading="@IsBusy" OnClick="HandleConfirmAsync">@ConfirmLabel</AppButton>
    </Footer>
</AppModal>

@code {
    private bool IsOpen { get; set; }
    private bool IsBusy { get; set; }
    private string MarkdownText { get; set; } = string.Empty;
    private string? InlineErrorMessage { get; set; }

    [Parameter, EditorRequired]
    public string ButtonLabel { get; set; } = default!;

    [Parameter, EditorRequired]
    public string ModalTitle { get; set; } = default!;

    [Parameter, EditorRequired]
    public string ModalDescription { get; set; } = default!;

    [Parameter]
    public string TextareaLabel { get; set; } = "Markdown";

    [Parameter]
    public string HelpText { get; set; } = "Paste prepared markdown here after generating it with your assistant.";

    [Parameter]
    public string Placeholder { get; set; } = string.Empty;

    [Parameter]
    public string ExampleMarkdown { get; set; } = string.Empty;

    [Parameter]
    public string ExampleTitle { get; set; } = "See an example";

    [Parameter]
    public IReadOnlyList<string> UsageSteps { get; set; } = [];

    [Parameter]
    public string CopyablePrompt { get; set; } = string.Empty;

    [Parameter]
    public string CopyablePromptTitle { get; set; } = "Prompt for AI";

    [Parameter]
    public string CopyablePromptDescription { get; set; } = "Copy this prompt into ChatGPT or another assistant, then paste the generated markdown back here.";

    [Parameter]
    public string ConfirmLabel { get; set; } = "Fill Form";

    [Parameter]
    public string ButtonVariant { get; set; } = "secondary";

    [Parameter]
    public string ButtonSize { get; set; } = "md";

    [Parameter]
    public string? ButtonClass { get; set; }

    [Parameter]
    public string FieldPrefix { get; set; } = "markdown-import";

    [Parameter, EditorRequired]
    public Func<string, Task<MarkdownImportApplyResult>> OnConfirmAsync { get; set; } = default!;

    private Task OpenAsync(MouseEventArgs _)
    {
        InlineErrorMessage = null;
        IsOpen = true;
        return Task.CompletedTask;
    }

    private Task CloseButtonAsync(MouseEventArgs _)
        => CloseAsync();

    private Task CloseAsync()
    {
        if (IsBusy)
        {
            return Task.CompletedTask;
        }

        IsOpen = false;
        InlineErrorMessage = null;
        return Task.CompletedTask;
    }

    private Task HandleMarkdownChanged(string? value)
    {
        MarkdownText = value ?? string.Empty;
        InlineErrorMessage = null;
        return Task.CompletedTask;
    }

    private async Task CopyPromptAsync(MouseEventArgs _)
    {
        if (string.IsNullOrWhiteSpace(CopyablePrompt))
        {
            return;
        }

        try
        {
            await JsRuntime.InvokeVoidAsync("watchAtlasStorage.copyText", CopyablePrompt);
            ToastState.ShowSuccess("Prompt copied.", "Paste it into your assistant and replace the placeholders before generating the markdown.");
        }
        catch (Exception exception)
        {
            InlineErrorMessage = $"The prompt could not be copied: {exception.Message}";
        }
    }

    private async Task HandleConfirmAsync(MouseEventArgs _)
    {
        if (string.IsNullOrWhiteSpace(MarkdownText))
        {
            InlineErrorMessage = "Paste markdown or choose a markdown file first.";
            return;
        }

        try
        {
            IsBusy = true;
            InlineErrorMessage = null;

            var result = await OnConfirmAsync.Invoke(MarkdownText);
            if (result.IsSuccess)
            {
                MarkdownText = string.Empty;
                IsOpen = false;
                return;
            }

            InlineErrorMessage = result.ErrorMessage ?? "The markdown could not be applied.";
        }
        finally
        {
            IsBusy = false;
        }
    }
}
