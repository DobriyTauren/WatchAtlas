<section class="@GridClass">
    @foreach (var entry in Entries)
    {
        <MediaCard Entry="entry" />
    }
</section>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<LibraryEntry> Entries { get; set; } = Array.Empty<LibraryEntry>();

    private string GridClass => "grid gap-4 lg:grid-cols-2";
}
