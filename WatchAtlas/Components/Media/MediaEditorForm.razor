@inject ToastState ToastState
@inject IMarkdownImportService MarkdownImportService

<EditForm Model="Media" OnSubmit="HandleSubmitAsync">
    <div class="space-y-6">
        @if (!string.IsNullOrWhiteSpace(DisplayedErrorMessage))
        {
            <div class="soft-block-strong border border-red-200/70 p-4 text-sm text-red-700">
                @DisplayedErrorMessage
            </div>
        }

        <AppSelect TValue="MediaType"
                   Id="@($"{FieldPrefix}-media-type")"
                   Label="Media Type"
                   Value="@Media.Type"
                   ValueChanged="HandleMediaTypeChanged"
                   Class="max-w-sm">
            <option value="@MediaType.Movie">Movie</option>
            <option value="@MediaType.Series">Series</option>
        </AppSelect>

        <div class="flex flex-wrap gap-3">
            @if (Media.Type == MediaType.Movie)
            {
                <MarkdownImportLauncher ButtonLabel="Fill Movie From Markdown"
                                        ModalTitle="Fill this movie from markdown"
                                        ModalDescription="Paste prepared markdown or upload a markdown file to fill this movie draft."
                                        ExampleMarkdown="@MarkdownImportExamples.Movie"
                                        FieldPrefix="@($"{FieldPrefix}-movie-markdown")"
                                        OnConfirmAsync="@(HandleMovieMarkdownImportAsync)" />
            }
            else
            {
                <MarkdownImportLauncher ButtonLabel="Fill Series From Markdown"
                                        ModalTitle="Fill this series from markdown"
                                        ModalDescription="Paste a prepared series breakdown to fill the series draft in one step."
                                        ExampleMarkdown="@MarkdownImportExamples.Series"
                                        FieldPrefix="@($"{FieldPrefix}-series-markdown")"
                                        OnConfirmAsync="@(HandleSeriesMarkdownImportAsync)" />

                <MarkdownImportLauncher ButtonLabel="Add Seasons From Markdown"
                                        ModalTitle="Add seasons from markdown"
                                        ModalDescription="Paste one or more season blocks to append them to the current series draft."
                                        ExampleMarkdown="@MarkdownImportExamples.Season"
                                        ConfirmLabel="Add Seasons"
                                        FieldPrefix="@($"{FieldPrefix}-season-markdown")"
                                        OnConfirmAsync="@(HandleSeasonMarkdownImportAsync)" />
            }
        </div>

        @if (Media.Type == MediaType.Movie)
        {
            <MovieFormFields Model="MovieForm" FieldPrefix="@FieldPrefix" />
        }
        else
        {
            <SeriesFormFields Model="SeriesForm" FieldPrefix="@FieldPrefix" />
        }

        <div class="flex flex-wrap gap-3">
            <AppButton Type="submit" IsLoading="@IsBusy">@SubmitLabel</AppButton>

            @if (AllowDelete)
            {
                <AppButton Variant="secondary" Disabled="@IsBusy" OnClick="HandleDeleteClickAsync">@DeleteLabel</AppButton>
            }

            @if (!string.IsNullOrWhiteSpace(CancelHref))
            {
                <AppButton Href="@CancelHref" Variant="secondary">Cancel</AppButton>
            }
        </div>
    </div>
</EditForm>

@code {
    private string? ValidationMessage { get; set; }
    private Guid BoundMediaId { get; set; }
    private MediaType BoundMediaType { get; set; }
    private bool IsInitialized { get; set; }
    private MovieFormModel MovieForm { get; set; } = new();
    private SeriesFormModel SeriesForm { get; set; } = new();

    [Parameter, EditorRequired]
    public MediaItem Media { get; set; } = default!;

    [Parameter, EditorRequired]
    public MovieDetails MovieDetails { get; set; } = default!;

    [Parameter, EditorRequired]
    public SeriesDetails SeriesDetails { get; set; } = default!;

    [Parameter, EditorRequired]
    public EventCallback OnSubmitRequested { get; set; }

    [Parameter]
    public EventCallback OnDeleteRequested { get; set; }

    [Parameter]
    public string SubmitLabel { get; set; } = "Save";

    [Parameter]
    public string DeleteLabel { get; set; } = "Delete";

    [Parameter]
    public string CancelHref { get; set; } = "/library";

    [Parameter]
    public string? ExternalErrorMessage { get; set; }

    [Parameter]
    public string FieldPrefix { get; set; } = "media-editor";

    [Parameter]
    public bool AllowDelete { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    private string? DisplayedErrorMessage => ExternalErrorMessage ?? ValidationMessage;

    protected override void OnParametersSet()
    {
        if (!IsInitialized || BoundMediaId != Media.Id || BoundMediaType != Media.Type)
        {
            MovieForm = MovieFormModel.From(Media, MovieDetails);
            SeriesForm = SeriesFormModel.From(Media, SeriesDetails);
            BoundMediaId = Media.Id;
            BoundMediaType = Media.Type;
            IsInitialized = true;
        }
    }

    private async Task HandleSubmitAsync(EditContext _)
    {
        ValidationMessage = Validate();
        if (!string.IsNullOrWhiteSpace(ValidationMessage))
        {
            ToastState.ShowWarning("Please review the form.", ValidationMessage);
            return;
        }

        ApplyViewState();
        await OnSubmitRequested.InvokeAsync();
    }

    private async Task HandleDeleteAsync()
    {
        ValidationMessage = null;
        await OnDeleteRequested.InvokeAsync();
    }

    private Task HandleDeleteClickAsync(MouseEventArgs _)
        => HandleDeleteAsync();

    private string? Validate()
        => Media.Type == MediaType.Movie
            ? MovieForm.GetValidationMessages().FirstOrDefault()
            : SeriesForm.GetValidationMessages().FirstOrDefault();

    private Task<MarkdownImportApplyResult> HandleMovieMarkdownImportAsync(string markdown)
    {
        var result = MarkdownImportService.ParseMovie(markdown);
        if (!result.IsSuccessful || result.Value is null)
        {
            return Task.FromResult(MarkdownImportApplyResult.Failure(result.ErrorMessage ?? "The markdown could not be applied."));
        }

        MovieForm.CopyFrom(result.Value);
        MovieForm.ApplyTo(Media, MovieDetails);
        StateHasChanged();
        ToastState.ShowSuccess("Movie details added.", "The draft was filled from your markdown.");

        if (result.Warnings.Count > 0)
        {
            ToastState.ShowInfo("A few details need a quick check.", result.Warnings[0]);
        }

        return Task.FromResult(MarkdownImportApplyResult.Success());
    }

    private Task<MarkdownImportApplyResult> HandleSeriesMarkdownImportAsync(string markdown)
    {
        var result = MarkdownImportService.ParseSeries(markdown);
        if (!result.IsSuccessful || result.Value is null)
        {
            return Task.FromResult(MarkdownImportApplyResult.Failure(result.ErrorMessage ?? "The markdown could not be applied."));
        }

        SeriesForm.CopyFrom(result.Value);
        SeriesForm.ApplyTo(Media, SeriesDetails);
        StateHasChanged();
        ToastState.ShowSuccess("Series details added.", "The draft was filled from your markdown.");

        if (result.Warnings.Count > 0)
        {
            ToastState.ShowInfo("A few details need a quick check.", result.Warnings[0]);
        }

        return Task.FromResult(MarkdownImportApplyResult.Success());
    }

    private Task<MarkdownImportApplyResult> HandleSeasonMarkdownImportAsync(string markdown)
    {
        var result = MarkdownImportService.ParseSeasons(markdown);
        if (!result.IsSuccessful || result.Value is null)
        {
            return Task.FromResult(MarkdownImportApplyResult.Failure(result.ErrorMessage ?? "The markdown could not be applied."));
        }

        var notices = SeriesForm.AppendImportedSeasons(result.Value).ToList();
        SeriesForm.ApplyTo(Media, SeriesDetails);
        StateHasChanged();
        ToastState.ShowSuccess("Seasons added.", "New seasons and episodes were appended to the current series draft.");

        var firstNotice = notices.Concat(result.Warnings).FirstOrDefault();
        if (!string.IsNullOrWhiteSpace(firstNotice))
        {
            ToastState.ShowInfo("Imported with a few notes.", firstNotice);
        }

        return Task.FromResult(MarkdownImportApplyResult.Success());
    }

    private void ApplyViewState()
    {
        if (Media.Type == MediaType.Movie)
        {
            MovieForm.ApplyTo(Media, MovieDetails);
            SeriesDetails.MediaItemId = Media.Id;
            return;
        }

        SeriesForm.ApplyTo(Media, SeriesDetails);
        MovieDetails.MediaItemId = Media.Id;
    }

    private Task HandleMediaTypeChanged(MediaType value)
    {
        if (Media.Type == MediaType.Movie)
        {
            MovieForm.ApplyTo(Media, MovieDetails);
        }
        else
        {
            SeriesForm.ApplyTo(Media, SeriesDetails);
        }

        Media.Type = value;

        if (value == MediaType.Movie)
        {
            MovieForm = MovieFormModel.From(Media, MovieDetails);
        }
        else
        {
            SeriesForm = SeriesFormModel.From(Media, SeriesDetails);
        }

        return Task.CompletedTask;
    }
}
