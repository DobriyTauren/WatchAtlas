<AppBadge Variant="@Variant">@Label</AppBadge>

@code {
    [Parameter, EditorRequired]
    public SeasonStatistics Statistics { get; set; } = default!;

    private string Label => Statistics.WatchedEpisodes switch
    {
        0 => "Not Started",
        var watched when watched == Statistics.TotalEpisodes && Statistics.TotalEpisodes > 0 => "Completed",
        _ => "In Progress"
    };

    private string Variant => Label switch
    {
        "Completed" => "success",
        "In Progress" => "outline",
        _ => "muted"
    };
}
