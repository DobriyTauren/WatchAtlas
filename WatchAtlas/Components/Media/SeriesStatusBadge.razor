<AppBadge Variant="@Variant">@Label</AppBadge>

@code {
    [Parameter, EditorRequired]
    public SeasonStatistics Statistics { get; set; } = default!;

    private string Label => Statistics.WatchedEpisodes switch
    {
        0 => L["Not Started"],
        var watched when watched == Statistics.TotalEpisodes && Statistics.TotalEpisodes > 0 => L["Completed"],
        _ => L["In Progress"]
    };

    private string Variant => Label switch
    {
        var value when value == L["Completed"] => "success",
        var value when value == L["In Progress"] => "outline",
        _ => "muted"
    };
}
