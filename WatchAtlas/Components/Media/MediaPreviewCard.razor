@using WatchAtlas.Extensions
@inject IStatisticsService StatisticsService

@{
    var status = WatchStatusHelper.GetStatus(Entry);
    var seriesProgress = Entry.Media.Type == MediaType.Series
        ? StatisticsService.CalculateSeriesProgress(Entry)
        : null;
    var runtimeMinutes = Entry.Media.Type == MediaType.Movie
        ? (Entry.Movie?.DurationMinutes ?? 0)
        : (seriesProgress?.WatchedMinutes ?? 0);
}

<article class="shell-card flex h-full flex-col gap-5 p-5 sm:p-6">
    <div class="flex items-start justify-between gap-4">
        <div class="space-y-2">
            <div class="flex flex-wrap items-center gap-2">
                <span class="tag-pill">@(Entry.Media.Type == MediaType.Movie ? "Movie" : "Series")</span>
                <span class="@GetStatusClass(status) rounded-full px-3 py-1 text-xs font-semibold">@GetStatusLabel(status)</span>
            </div>

            <div>
                <h3 class="text-xl">@Entry.Media.Title</h3>

                @if (!string.IsNullOrWhiteSpace(Entry.Media.Description))
                {
                    <p class="mt-2 line-clamp-3 text-sm leading-6 text-muted">@Entry.Media.Description</p>
                }
                else
                {
                    <p class="mt-2 text-sm leading-6 text-muted">A polished placeholder card for the future watch-entry detail view.</p>
                }
            </div>
        </div>

        <span class="rounded-3xl bg-white/50 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-muted">
            @(Entry.Media.PersonalRating is { } rating ? $"{rating}/10" : "Draft")
        </span>
    </div>

    @if (Entry.Media.Genres.Count > 0)
    {
        <div class="flex flex-wrap gap-2">
            @foreach (var genre in Entry.Media.Genres.Take(3))
            {
                <span class="rounded-full border border-border bg-surface-strong px-3 py-1 text-xs text-muted">@genre</span>
            }
        </div>
    }

    <div class="grid gap-3 text-sm text-muted sm:grid-cols-2">
        <div class="rounded-2xl bg-white/40 p-4">
            <p class="font-semibold text-text">Watch Time</p>
            <p class="mt-1">@(runtimeMinutes > 0 ? runtimeMinutes.ToReadableDuration() : "Not tracked yet")</p>
        </div>

        <div class="rounded-2xl bg-white/40 p-4">
            <p class="font-semibold text-text">Progress</p>
            <p class="mt-1">
                @if (seriesProgress is not null)
                {
                    @($"{seriesProgress.WatchedEpisodes}/{seriesProgress.TotalEpisodes} episodes")
                }
                else
                {
                    @(Entry.Movie?.IsWatched == true ? "Watched" : "Unwatched")
                }
            </p>
        </div>
    </div>

    <div class="mt-auto flex flex-wrap gap-3 pt-1">
        <a class="secondary-button" href="/media/@Entry.Media.Id">Open Details</a>
        <a class="primary-button" href="/media/new">Add Another</a>
    </div>
</article>

@code {
    [Parameter, EditorRequired]
    public LibraryEntry Entry { get; set; } = default!;

    private static string GetStatusLabel(WatchStatus status) => status switch
    {
        WatchStatus.Completed => "Completed",
        WatchStatus.InProgress => "In Progress",
        _ => "Not Started"
    };

    private static string GetStatusClass(WatchStatus status) => status switch
    {
        WatchStatus.Completed => "bg-emerald-100 text-emerald-700",
        WatchStatus.InProgress => "bg-sky-100 text-sky-700",
        _ => "bg-white/60 text-muted"
    };
}
