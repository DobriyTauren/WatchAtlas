@using WatchAtlas.Extensions

@{
    var status = WatchStatusHelper.GetStatus(Entry);
    var completion = WatchStatusHelper.GetCompletionPercent(Entry);
    var runtimeMinutes = WatchStatusHelper.GetTrackedMinutes(Entry);
}

<a href="@MediaRouteHelper.GetDetailsHref(Entry)"
   class="group block rounded-[2rem] focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/70 focus-visible:ring-offset-2 focus-visible:ring-offset-surface"
   aria-label="@($"Open details for {Entry.Media.Title}")">
    <article class="shell-card grid gap-5 p-5 transition duration-200 group-hover:-translate-y-0.5 group-hover:border-accent/60 group-hover:shadow-[0_24px_70px_-42px_rgba(120,101,214,0.42)] sm:p-6 lg:grid-cols-[9rem,1fr]">
        <div class="mx-auto hidden w-full max-w-[9rem] space-y-3 lg:block">
            <div class="aspect-[2/3] overflow-hidden rounded-[1.5rem] border border-border/70 bg-surface-soft/60">
                @if (!string.IsNullOrWhiteSpace(Entry.Media.CoverImageUrl))
                {
                    <img src="@Entry.Media.CoverImageUrl"
                         alt="@($"{Entry.Media.Title} cover")"
                         class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]" />
                }
                else
                {
                    <div class="movie-cover-fallback h-full p-5">
                        <span class="movie-cover-fallback__badge">@GetCoverBadge()</span>
                        <h3 class="text-xl text-text">@Entry.Media.Title</h3>
                    </div>
                }
            </div>

            <ProgressBar Label="Completion" Value="@completion" Max="100" />
        </div>

        <div class="min-w-0 space-y-4">
            <div class="flex flex-wrap items-center gap-2">
                <MediaTypeBadge Type="@Entry.Media.Type" />
                <MediaStatusBadge Status="@status" />

                @if (Entry.Media.PersonalRating is { } rating)
                {
                    <span class="rating-pill">@rating/10</span>
                }
            </div>

            <div class="space-y-2">
                <div class="flex items-start justify-between gap-4">
                    <h3 class="text-2xl transition-colors duration-200 group-hover:text-accent">@Entry.Media.Title</h3>
                </div>

                <p class="text-sm leading-7 text-muted">
                    @(string.IsNullOrWhiteSpace(Entry.Media.Description)
                        ? "No description yet. Open details to enrich this entry."
                        : Entry.Media.Description)
                </p>
            </div>

            @if (Entry.Media.Genres.Count > 0)
            {
                <div class="flex flex-wrap gap-2">
                    @foreach (var genre in Entry.Media.Genres)
                    {
                        <AppBadge Variant="outline">@genre</AppBadge>
                    }
                </div>
            }

            <div class="grid gap-3 text-sm text-muted sm:grid-cols-3">
                <div class="soft-block p-4">
                    <p class="font-semibold text-text">Created</p>
                    <p class="mt-1">@Entry.Media.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</p>
                </div>

                <div class="soft-block p-4">
                    <p class="font-semibold text-text">Updated</p>
                    <p class="mt-1">@Entry.Media.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy")</p>
                </div>

                <div class="soft-block p-4">
                    <p class="font-semibold text-text">Tracked Time</p>
                    <p class="mt-1">@(runtimeMinutes > 0 ? runtimeMinutes.ToReadableDuration() : "Not tracked yet")</p>
                </div>
            </div>
        </div>
    </article>
</a>

@code {
    [Parameter, EditorRequired]
    public LibraryEntry Entry { get; set; } = default!;

    private string GetCoverBadge()
        => Entry.Media.Type == MediaType.Movie ? "Movie" : "Series";
}
