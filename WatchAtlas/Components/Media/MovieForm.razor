@inject ToastState ToastState
@inject IMarkdownImportService MarkdownImportService

<EditForm EditContext="EditContext" OnValidSubmit="HandleValidSubmitAsync" OnInvalidSubmit="HandleInvalidSubmit">
    <DataAnnotationsValidator />

    <div class="space-y-6">
        @if (!string.IsNullOrWhiteSpace(ExternalErrorMessage))
        {
            <div class="soft-block-strong border border-red-200/70 p-4 text-sm text-red-700">
                @ExternalErrorMessage
            </div>
        }

        @if (EditContext.GetValidationMessages().Any())
        {
            <ValidationSummary class="space-y-1 rounded-3xl border border-red-200/70 bg-red-50/80 px-4 py-3 text-sm text-red-700" />
        }

        <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
            <div class="flex flex-wrap gap-3">
                <MarkdownImportLauncher ButtonLabel="@L["Fill From Markdown"]"
                                        ModalTitle="@L["Fill this movie from markdown"]"
                                        ModalDescription="@L["Paste markdown for one movie, or copy the message below and let your assistant prepare it for you."]"
                                        ExampleMarkdown="@MarkdownImportExamples.Movie"
                                        ExampleTitle="@L["See a movie example"]"
                                    UsageSteps="@MarkdownImportExamples.MovieImportSteps"
                                    CopyablePrompt="@MarkdownImportExamples.MovieAiPrompt"
                                    CopyablePromptTitle="@L["Message for ChatGPT or Claude"]"
                                    CopyablePromptDescription="@L["Copy this message into your assistant, then paste the markdown back here."]"
                                    PromptPrimaryToken="[MOVIE TITLE]"
                                        PromptPrimaryLabel="@L["Movie title"]"
                                        PromptPrimaryPlaceholder="The Matrix"
                                        PromptPrimaryHelpText="@L["We'll place this title into the copied message automatically."]"
                                        PromptPrimaryValue="@Model.Title"
                                        Placeholder="# Movie&#10;Title: ...&#10;Universe: ...&#10;Genres: ...&#10;Duration: 120"
                                        FieldPrefix="@($"{FieldPrefix}-markdown")"
                                        OnConfirmAsync="@(HandleMarkdownImportAsync)" />
            </div>

            <div class="flex flex-wrap gap-3 lg:justify-end">
                <AppButton Type="submit" IsLoading="@IsBusy">@SubmitLabel</AppButton>

                @if (!string.IsNullOrWhiteSpace(CancelHref))
                {
                    <AppButton Href="@CancelHref" Variant="secondary">@L["Cancel"]</AppButton>
                }
            </div>
        </div>

        <MovieFormFields Model="Model" FieldPrefix="@FieldPrefix" />
    </div>
</EditForm>

@code {
    private EditContext EditContext { get; set; } = default!;
    private MovieFormModel? BoundModel { get; set; }

    [Parameter, EditorRequired]
    public MovieFormModel Model { get; set; } = default!;

    [Parameter, EditorRequired]
    public EventCallback OnSubmitRequested { get; set; }

    [Parameter]
    public string SubmitLabel { get; set; } = "Save Movie";

    [Parameter]
    public string CancelHref { get; set; } = "/library";

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public string? ExternalErrorMessage { get; set; }

    [Parameter]
    public string FieldPrefix { get; set; } = "movie-form";

    protected override void OnParametersSet()
    {
        if (!ReferenceEquals(BoundModel, Model))
        {
            EditContext = new EditContext(Model);
            BoundModel = Model;
        }
    }

    private Task HandleValidSubmitAsync()
        => OnSubmitRequested.InvokeAsync();

    private Task<MarkdownImportApplyResult> HandleMarkdownImportAsync(string markdown)
    {
        var result = MarkdownImportService.ParseMovie(markdown);
        if (!result.IsSuccessful || result.Value is null)
        {
            return Task.FromResult(MarkdownImportApplyResult.Failure(result.ErrorMessage ?? L["The markdown could not be applied."]));
        }

        Model.CopyFrom(result.Value);
        RefreshEditContext();
        ToastState.ShowSuccess(L["Movie details added."], L["Your markdown filled the form."]);

        if (result.Warnings.Count > 0)
        {
            ToastState.ShowInfo(L["A few details need a quick check."], result.Warnings[0]);
        }

        return Task.FromResult(MarkdownImportApplyResult.Success());
    }

    private void HandleInvalidSubmit(EditContext editContext)
    {
        var firstMessage = editContext.GetValidationMessages().FirstOrDefault();
        ToastState.ShowWarning(L["Please review the form fields."], firstMessage ?? L["A few movie details still need attention before saving."]);
    }

    private void RefreshEditContext()
    {
        EditContext = new EditContext(Model);
        BoundModel = Model;
        StateHasChanged();
    }
}
