@inject ToastState ToastState
@inject IMarkdownImportService MarkdownImportService

<EditForm EditContext="EditContext" OnValidSubmit="HandleValidSubmitAsync" OnInvalidSubmit="HandleInvalidSubmit">
    <DataAnnotationsValidator />

    <div class="space-y-6">
        @if (!string.IsNullOrWhiteSpace(ExternalErrorMessage))
        {
            <div class="soft-block-strong border border-red-200/70 p-4 text-sm text-red-700">
                @ExternalErrorMessage
            </div>
        }

        @if (EditContext.GetValidationMessages().Any())
        {
            <ValidationSummary class="space-y-1 rounded-3xl border border-red-200/70 bg-red-50/80 px-4 py-3 text-sm text-red-700" />
        }

        <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
            <div class="flex flex-wrap gap-3">
                <MarkdownImportLauncher ButtonLabel="Fill Series From Markdown"
                                        ModalTitle="Fill this series from markdown"
                                        ModalDescription="Paste one clean markdown document for a single series, or copy the AI prompt below to generate it automatically in the right format."
                                        ExampleMarkdown="@MarkdownImportExamples.Series"
                                        ExampleTitle="See a full series example"
                                        UsageSteps="@MarkdownImportExamples.SeriesImportSteps"
                                        CopyablePrompt="@MarkdownImportExamples.SeriesAiPrompt"
                                        CopyablePromptTitle="Prompt for ChatGPT or Claude"
                                        CopyablePromptDescription="Copy this, replace the placeholder with the exact show title, and ask your assistant for import-ready markdown."
                                        Placeholder="# Series&#10;Title: ...&#10;Genres: ...&#10;&#10;## Season 1&#10;- Episode 1: ..."
                                        FieldPrefix="@($"{FieldPrefix}-series-markdown")"
                                        OnConfirmAsync="@(HandleSeriesMarkdownImportAsync)" />

                <MarkdownImportLauncher ButtonLabel="Add Seasons From Markdown"
                                        ModalTitle="Add seasons from markdown"
                                        ModalDescription="Paste one or more season blocks, or copy the AI prompt below to generate only the seasons you still need to add."
                                        ExampleMarkdown="@MarkdownImportExamples.Season"
                                        ExampleTitle="See a season block example"
                                        UsageSteps="@MarkdownImportExamples.SeasonImportSteps"
                                        CopyablePrompt="@MarkdownImportExamples.SeasonAiPrompt"
                                        CopyablePromptTitle="Prompt for missing seasons"
                                        CopyablePromptDescription="Use this when you already have a series draft and only want to append more seasons in the exact import format."
                                        Placeholder="## Season 3: Optional Title&#10;- Episode 1: ...&#10;  - Duration: 46"
                                        ConfirmLabel="Add Seasons"
                                        FieldPrefix="@($"{FieldPrefix}-season-markdown")"
                                        OnConfirmAsync="@(HandleSeasonMarkdownImportAsync)" />
            </div>

            <div class="flex flex-wrap gap-3 lg:justify-end">
                <AppButton Type="submit" IsLoading="@IsBusy">@SubmitLabel</AppButton>

                @if (!string.IsNullOrWhiteSpace(CancelHref))
                {
                    <AppButton Href="@CancelHref" Variant="secondary">Cancel</AppButton>
                }
            </div>
        </div>

        <SeriesFormFields Model="Model" FieldPrefix="@FieldPrefix" />
    </div>
</EditForm>

@code {
    private EditContext EditContext { get; set; } = default!;
    private SeriesFormModel? BoundModel { get; set; }

    [Parameter, EditorRequired]
    public SeriesFormModel Model { get; set; } = default!;

    [Parameter, EditorRequired]
    public EventCallback OnSubmitRequested { get; set; }

    [Parameter]
    public string SubmitLabel { get; set; } = "Save Series";

    [Parameter]
    public string CancelHref { get; set; } = "/library";

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public string? ExternalErrorMessage { get; set; }

    [Parameter]
    public string FieldPrefix { get; set; } = "series-form";

    protected override void OnParametersSet()
    {
        if (!ReferenceEquals(BoundModel, Model))
        {
            EditContext = new EditContext(Model);
            BoundModel = Model;
        }
    }

    private Task HandleValidSubmitAsync()
        => OnSubmitRequested.InvokeAsync();

    private Task<MarkdownImportApplyResult> HandleSeriesMarkdownImportAsync(string markdown)
    {
        var result = MarkdownImportService.ParseSeries(markdown);
        if (!result.IsSuccessful || result.Value is null)
        {
            return Task.FromResult(MarkdownImportApplyResult.Failure(result.ErrorMessage ?? "The markdown could not be applied."));
        }

        Model.CopyFrom(result.Value);
        RefreshEditContext();
        ToastState.ShowSuccess("Series details added.", "The series form was filled from your markdown.");

        if (result.Warnings.Count > 0)
        {
            ToastState.ShowInfo("A few details need a quick check.", result.Warnings[0]);
        }

        return Task.FromResult(MarkdownImportApplyResult.Success());
    }

    private Task<MarkdownImportApplyResult> HandleSeasonMarkdownImportAsync(string markdown)
    {
        var result = MarkdownImportService.ParseSeasons(markdown);
        if (!result.IsSuccessful || result.Value is null)
        {
            return Task.FromResult(MarkdownImportApplyResult.Failure(result.ErrorMessage ?? "The markdown could not be applied."));
        }

        var notices = Model.AppendImportedSeasons(result.Value).ToList();
        RefreshEditContext();
        ToastState.ShowSuccess("Seasons added.", "New seasons and episodes were appended to the current series draft.");

        var firstNotice = notices.Concat(result.Warnings).FirstOrDefault();
        if (!string.IsNullOrWhiteSpace(firstNotice))
        {
            ToastState.ShowInfo("Imported with a few notes.", firstNotice);
        }

        return Task.FromResult(MarkdownImportApplyResult.Success());
    }

    private void HandleInvalidSubmit(EditContext editContext)
    {
        var firstMessage = editContext.GetValidationMessages().FirstOrDefault();
        ToastState.ShowWarning("Please review the series form.", firstMessage ?? "Some series details still need attention before save.");
    }

    private void RefreshEditContext()
    {
        EditContext = new EditContext(Model);
        BoundModel = Model;
        StateHasChanged();
    }
}
