@inject FilterState FilterState
@inject ThemeState ThemeState

<header class="shell-card sticky top-4 z-20 flex flex-col gap-4 p-4 sm:p-5">
    <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
        <div class="flex flex-1 items-center gap-3 rounded-full border border-border bg-surface-strong px-4 py-3">
            <span class="text-muted">Search</span>
            <input class="w-full border-0 bg-transparent p-0 text-sm text-text outline-none placeholder:text-muted"
                   placeholder="Search titles from your library"
                   @bind="SearchTerm"
                   @bind:event="oninput" />
        </div>

        <div class="flex flex-wrap items-center gap-3">
            <button class="secondary-button" type="button" @onclick="CycleThemeAsync">
                Theme: @ThemeState.CurrentTheme.DisplayName
            </button>
            <a class="primary-button" href="/media/new">Add Movie or Series</a>
        </div>
    </div>

    <div class="flex flex-wrap items-center gap-2">
        @foreach (var theme in ThemeState.AvailableThemes)
        {
            <button class="@GetThemeButtonClass(theme)" type="button" @onclick="() => ThemeState.ApplyThemeAsync(theme.Mode)">
                @theme.AccentLabel
            </button>
        }
    </div>
</header>

@code {
    private string SearchTerm
    {
        get => FilterState.Options.SearchTerm;
        set => FilterState.SetSearchTerm(value);
    }

    private Task CycleThemeAsync()
    {
        var themes = ThemeState.AvailableThemes;
        var currentIndex = themes.ToList().FindIndex(theme => theme.Mode == ThemeState.CurrentTheme.Mode);
        var nextTheme = themes[(currentIndex + 1) % themes.Count];
        return ThemeState.ApplyThemeAsync(nextTheme.Mode);
    }

    private string GetThemeButtonClass(ThemeSettings theme)
        => theme.Mode == ThemeState.CurrentTheme.Mode
            ? "rounded-full border border-accent/30 bg-accent-soft px-3 py-2 text-xs font-semibold text-text"
            : "rounded-full border border-border bg-surface-strong px-3 py-2 text-xs font-semibold text-muted transition hover:border-accent/30 hover:text-text";
}
