@inject FilterState FilterState

<header class="shell-card sticky top-4 z-20 flex flex-col gap-4 p-4 sm:p-5">
    <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
        <AppInput Class="flex-1"
                  InputClassName="rounded-full border-0 bg-surface-strong"
                  Value="@SearchTerm"
                  ValueChanged="HandleSearchChanged"
                  Placeholder="Search titles from your library"
                  aria-label="Search titles" />

        <div class="flex flex-wrap items-center gap-3">
            <ThemeSwitcher Compact="true" />
            <AppButton Href="/media/new">Add Movie or Series</AppButton>
        </div>
    </div>
</header>

@code {
    private string SearchTerm
    {
        get => FilterState.Options.SearchTerm;
        set => FilterState.SetSearchTerm(value);
    }

    private Task HandleSearchChanged(string? value)
    {
        SearchTerm = value ?? string.Empty;
        return Task.CompletedTask;
    }
}
