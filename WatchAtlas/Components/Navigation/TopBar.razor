@implements IDisposable
@inject FilterState FilterState
@inject NavigationManager NavigationManager

<header class="shell-card sticky top-4 z-20 flex flex-col gap-4 p-4 sm:p-5" role="search" aria-label="Library search and quick actions">
    <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
        <AppInput Class="flex-1"
                  InputClassName="rounded-full border-0 bg-surface-strong"
                  Value="@SearchTerm"
                  ValueChanged="HandleSearchChanged"
                  Placeholder="Search titles from your library"
                  aria-label="Search titles" />

        <div class="flex flex-wrap items-center gap-3 max-sm:w-full">
            <ThemeSwitcher Compact="true" ShowCurrentButton="false" />
            <AppButton Href="media/new" Class="max-sm:flex-1">Add Movie or Series</AppButton>
        </div>
    </div>
</header>

@code {
    protected override void OnInitialized()
    {
        FilterState.Changed += HandleFilterChanged;
    }

    private string SearchTerm
    {
        get => FilterState.Options.SearchTerm;
        set => FilterState.SetSearchTerm(value);
    }

    private Task HandleSearchChanged(string? value)
    {
        SearchTerm = value ?? string.Empty;

        if (!IsLibraryRoute())
        {
            NavigationManager.NavigateTo("library");
        }

        return Task.CompletedTask;
    }

    private bool IsLibraryRoute()
    {
        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        return relativePath.Equals("library", StringComparison.OrdinalIgnoreCase);
    }

    private void HandleFilterChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        FilterState.Changed -= HandleFilterChanged;
    }
}
