<div class="@WrapperClass">
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <label class="app-field-label" for="@Id">@Label</label>
    }

    <input id="@Id"
           type="@Type"
           class="@InputClass"
           value="@Value"
           placeholder="@Placeholder"
           disabled="@Disabled"
           @oninput="HandleInput"
           @attributes="AdditionalAttributes" />

    @if (!string.IsNullOrWhiteSpace(HelpText))
    {
        <p class="app-field-help">@HelpText</p>
    }
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public string Type { get; set; } = "text";

    [Parameter]
    public string? Placeholder { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string? HelpText { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string? InputClassName { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string WrapperClass => string.Join(" ", new[] { "app-field", Class }.Where(value => !string.IsNullOrWhiteSpace(value)));
    private string InputClass => string.Join(" ", new[] { "app-input", InputClassName }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private Task HandleInput(ChangeEventArgs args)
        => ValueChanged.InvokeAsync(args.Value?.ToString());
}
