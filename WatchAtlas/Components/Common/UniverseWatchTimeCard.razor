@using WatchAtlas.Extensions
@using WatchAtlas.Models.Enums

<AppCard Class="h-full">
    <div class="space-y-5">
        <div class="flex flex-wrap items-start justify-between gap-3">
            <div class="space-y-2">
                <div class="flex flex-wrap items-center gap-2">
                    <AppBadge>@Statistics.Universe</AppBadge>
                    <AppBadge Variant="outline">@Statistics.TitleCount.ToCountLabel("title")</AppBadge>
                </div>
                <h3 class="text-xl">@Statistics.TotalWatchedMinutes.ToReadableDuration()</h3>
            </div>
        </div>

        <div class="grid gap-3 text-sm text-muted sm:grid-cols-2">
            <div class="soft-block p-4">
                <p class="font-semibold text-text">@MoviesLabel</p>
                <p class="mt-1">@Statistics.WatchedMovieMinutes.ToReadableDuration()</p>
            </div>

            <div class="soft-block p-4">
                <p class="font-semibold text-text">@EpisodesLabel</p>
                <p class="mt-1">@Statistics.WatchedEpisodeMinutes.ToReadableDuration()</p>
            </div>
        </div>
    </div>
</AppCard>

@code {
    [Parameter, EditorRequired]
    public UniverseWatchTimeStatistics Statistics { get; set; } = default!;

    private string MoviesLabel
        => LocalizedText.GetCurrentLanguage() == AppLanguage.Russian
            ? "\u0424\u0438\u043b\u044c\u043c\u044b"
            : "Movies";

    private string EpisodesLabel
        => LocalizedText.GetCurrentLanguage() == AppLanguage.Russian
            ? "\u042d\u043f\u0438\u0437\u043e\u0434\u044b"
            : "Episodes";
}
