<div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div class="space-y-3">
        @if (!string.IsNullOrWhiteSpace(Eyebrow))
        {
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-muted">@Eyebrow</p>
        }

        <div class="space-y-2">
            <h2 class="@TitleClass">@Title</h2>

            @if (!string.IsNullOrWhiteSpace(Description))
            {
                <p class="max-w-3xl text-sm leading-7 text-muted sm:text-base">@Description</p>
            }
        </div>
    </div>

    @if (Actions is not null)
    {
        <div class="flex flex-wrap items-center gap-3">
            @Actions
        </div>
    }
</div>

@code {
    [Parameter]
    public string? Eyebrow { get; set; }

    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? Description { get; set; }

    [Parameter]
    public bool IsPageTitle { get; set; }

    [Parameter]
    public RenderFragment? Actions { get; set; }

    private string TitleClass => IsPageTitle ? "text-3xl sm:text-4xl" : "text-2xl";
}
