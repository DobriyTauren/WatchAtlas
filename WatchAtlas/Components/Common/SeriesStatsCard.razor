<AppCard Class="h-full">
    <div class="space-y-5">
        <div class="flex items-start justify-between gap-4">
            <div class="space-y-2">
                <div class="flex flex-wrap items-center gap-2">
                    <MediaStatusBadge Status="@Statistics.Status" />
                    <AppBadge Variant="outline">@Statistics.SeasonCount.ToCountLabel("season")</AppBadge>
                </div>
                <h3 class="text-xl">@Statistics.Title</h3>
            </div>

            @if (!string.IsNullOrWhiteSpace(Statistics.CoverImageUrl))
            {
                <img src="@Statistics.CoverImageUrl"
                     alt="@($"{Statistics.Title} cover")"
                     class="h-16 w-12 rounded-2xl object-cover" />
            }
        </div>

        <ProgressBar Label="Completion"
                     Value="@Statistics.CompletionPercent"
                     Max="100" />

        <div class="grid gap-3 text-sm text-muted sm:grid-cols-2">
            <div class="soft-block p-4">
                <p class="font-semibold text-text">Episodes</p>
                <p class="mt-1">@Statistics.WatchedEpisodes / @Statistics.TotalEpisodes watched</p>
            </div>

            <div class="soft-block p-4">
                <p class="font-semibold text-text">Watch Time</p>
                <p class="mt-1">@Statistics.WatchedMinutes.ToReadableDuration()</p>
            </div>
        </div>
    </div>
</AppCard>

@code {
    [Parameter, EditorRequired]
    public SeriesStatistics Statistics { get; set; } = default!;
}
