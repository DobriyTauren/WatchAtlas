@if (!string.IsNullOrWhiteSpace(Href))
{
    <a href="@Href" class="@CssClass" @attributes="AdditionalAttributes">@ChildContent</a>
}
else
{
    <button type="@Type" class="@CssClass" disabled="@Disabled" @onclick="OnClick" @attributes="AdditionalAttributes">@ChildContent</button>
}

@code {
    [Parameter]
    public string? Href { get; set; }

    [Parameter]
    public string Variant { get; set; } = "primary";

    [Parameter]
    public string Size { get; set; } = "md";

    [Parameter]
    public string Type { get; set; } = "button";

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    [Parameter, EditorRequired]
    public RenderFragment ChildContent { get; set; } = default!;

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => string.Join(" ", new[]
    {
        "app-button",
        Variant switch
        {
            "secondary" => "app-button-secondary",
            "ghost" => "app-button-ghost",
            _ => "app-button-primary"
        },
        Size switch
        {
            "sm" => "app-button-sm",
            "lg" => "app-button-lg",
            _ => "app-button-md"
        },
        Disabled ? "app-button-disabled" : null,
        Class
    }.Where(value => !string.IsNullOrWhiteSpace(value)));
}
