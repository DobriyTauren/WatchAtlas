<section class="@CssClass">
    @ChildContent
</section>

@code {
    [Parameter]
    public string? Class { get; set; }

    [Parameter, EditorRequired]
    public RenderFragment ChildContent { get; set; } = default!;

    private string CssClass => string.Join(" ", new[] { "filter-bar", Class }.Where(value => !string.IsNullOrWhiteSpace(value)));
}
