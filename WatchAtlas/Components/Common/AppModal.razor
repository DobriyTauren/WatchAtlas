@if (IsOpen)
{
    <div class="app-modal-backdrop" @onclick="HandleBackdropClick">
        <div class="app-modal-panel"
             @ref="PanelRef"
             role="dialog"
             aria-modal="true"
             aria-labelledby="@TitleId"
             aria-describedby="@AriaDescriptionId"
             tabindex="-1"
             @onkeydown="HandleKeyDownAsync"
             @onclick:stopPropagation="true">
            @if (!string.IsNullOrWhiteSpace(Title) || !string.IsNullOrWhiteSpace(Description))
            {
                <div class="space-y-2">
                    @if (!string.IsNullOrWhiteSpace(Title))
                    {
                        <h2 id="@TitleId" class="text-2xl">@Title</h2>
                    }

                    @if (!string.IsNullOrWhiteSpace(Description))
                    {
                        <p id="@DescriptionId" class="text-sm leading-7 text-muted">@Description</p>
                    }
                </div>
            }

            <div>
                @ChildContent
            </div>

            @if (Footer is not null)
            {
                <div class="flex flex-wrap justify-end gap-3">
                    @Footer
                </div>
            }
        </div>
    </div>
}

@code {
    [Inject]
    private IJSRuntime JsRuntime { get; set; } = default!;

    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public string? Description { get; set; }

    [Parameter]
    public bool CloseOnBackdropClick { get; set; } = true;

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter, EditorRequired]
    public RenderFragment ChildContent { get; set; } = default!;

    [Parameter]
    public RenderFragment? Footer { get; set; }

    private string TitleId { get; } = $"modal-title-{Guid.NewGuid():N}";
    private string DescriptionId { get; } = $"modal-description-{Guid.NewGuid():N}";
    private string? AriaDescriptionId => !string.IsNullOrWhiteSpace(Description) ? DescriptionId : null;
    private ElementReference PanelRef { get; set; }
    private bool WasOpen { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (IsOpen && !WasOpen)
        {
            await JsRuntime.InvokeVoidAsync("watchAtlasStorage.focusModal", PanelRef);
        }

        WasOpen = IsOpen;
    }

    private Task HandleBackdropClick()
        => CloseOnBackdropClick ? OnClose.InvokeAsync() : Task.CompletedTask;

    private Task HandleKeyDownAsync(KeyboardEventArgs args)
        => args.Key == "Escape" ? OnClose.InvokeAsync() : Task.CompletedTask;
}
