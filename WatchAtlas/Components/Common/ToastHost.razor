@implements IDisposable
@inject ToastState ToastState

@if (ToastState.Messages.Count > 0)
{
    <div class="toast-host" aria-live="polite" aria-atomic="false">
        @foreach (var message in ToastState.Messages)
        {
            <article class="@GetToastClass(message)"
                     role="@(message.Tone == ToastTone.Error ? "alert" : "status")">
                <div class="min-w-0 space-y-1">
                    <p class="toast__title">@message.Title</p>
                    @if (!string.IsNullOrWhiteSpace(message.Description))
                    {
                        <p class="toast__description">@message.Description</p>
                    }
                </div>

                <button class="toast__dismiss"
                        type="button"
                        aria-label="Dismiss notification"
                        @onclick="() => Dismiss(message.Id)">
                    x
                </button>
            </article>
        }
    </div>
}

@code {
    protected override void OnInitialized()
    {
        ToastState.Changed += HandleChanged;
    }

    private string GetToastClass(ToastMessage message) => string.Join(" ", new[]
    {
        "toast",
        message.Tone switch
        {
            ToastTone.Success => "toast-success",
            ToastTone.Warning => "toast-warning",
            ToastTone.Error => "toast-error",
            _ => "toast-info"
        }
    });

    private void Dismiss(Guid id)
        => ToastState.Dismiss(id);

    private void HandleChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        ToastState.Changed -= HandleChanged;
    }
}
