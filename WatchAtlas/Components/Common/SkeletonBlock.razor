<div class="@CssClass"
     aria-hidden="true"
     @attributes="AdditionalAttributes"></div>

@code {
    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string HeightClass { get; set; } = "h-4";

    [Parameter]
    public string RadiusClass { get; set; } = "rounded-2xl";

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => string.Join(" ", new[]
    {
        "skeleton-block",
        HeightClass,
        RadiusClass,
        Class
    }.Where(value => !string.IsNullOrWhiteSpace(value)));
}
