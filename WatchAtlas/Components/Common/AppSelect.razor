@typeparam TValue

<div class="@WrapperClass">
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <label class="app-field-label" for="@Id">@Label</label>
    }

    <select id="@Id"
            class="@SelectClass"
            value="@BindConverter.FormatValue(Value)"
            disabled="@Disabled"
            @onchange="HandleChanged"
            @attributes="AdditionalAttributes">
        @ChildContent
    </select>

    @if (!string.IsNullOrWhiteSpace(HelpText))
    {
        <p class="app-field-help">@HelpText</p>
    }
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public TValue Value { get; set; } = default!;

    [Parameter]
    public EventCallback<TValue> ValueChanged { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string? HelpText { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string? SelectClassName { get; set; }

    [Parameter, EditorRequired]
    public RenderFragment ChildContent { get; set; } = default!;

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string WrapperClass => string.Join(" ", new[] { "app-field", Class }.Where(value => !string.IsNullOrWhiteSpace(value)));
    private string SelectClass => string.Join(" ", new[] { "app-select", SelectClassName }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private Task HandleChanged(ChangeEventArgs args)
    {
        if (BindConverter.TryConvertTo<TValue>(args.Value, System.Globalization.CultureInfo.CurrentCulture, out var result))
        {
            return ValueChanged.InvokeAsync(result);
        }

        return ValueChanged.InvokeAsync(default!);
    }
}
