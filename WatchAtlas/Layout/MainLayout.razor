@inherits LayoutComponentBase

@implements IDisposable
@inject ThemeState ThemeState

<div class="app-shell-theme relative min-h-screen overflow-hidden" data-theme="@ThemeState.CurrentTheme.ThemeKey">
    <div class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[28rem] bg-hero-mist opacity-90"></div>
    <div class="theme-orb-primary pointer-events-none absolute -right-24 top-20 -z-10 h-64 w-64 rounded-full blur-3xl"></div>
    <div class="theme-orb-secondary pointer-events-none absolute -left-20 bottom-24 -z-10 h-72 w-72 rounded-full blur-3xl"></div>

    <div class="app-container flex min-h-screen gap-6 pb-28 pt-4 lg:pb-6">
        <Sidebar />

        <div class="flex min-w-0 flex-1 flex-col gap-6">
            <TopBar />

            <main class="flex-1 animate-rise">
                @Body
            </main>
        </div>
    </div>

    <MobileNav />
</div>

@code {
    protected override void OnInitialized()
    {
        ThemeState.Changed += HandleThemeChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ThemeState.InitializeAsync();
        }
    }

    private void HandleThemeChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        ThemeState.Changed -= HandleThemeChanged;
    }
}
