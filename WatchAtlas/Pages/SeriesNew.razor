@page "/series/new"
@inject LibraryState LibraryState
@inject NavigationManager NavigationManager
@inject ToastState ToastState

<PageTitle>@L["Create Show"]</PageTitle>

<section class="space-y-8">
    <PageHeader Eyebrow="@L["Create Show"]"
                Title="@L["Add a show to your library."]"
                Subtitle="@L["Set up the show, then add seasons and episodes whenever you're ready."]" />

    <section>
        <AppCard>
            <SeriesForm Model="Form"
                        SubmitLabel="@L["Create Show"]"
                        CancelHref="library"
                        FieldPrefix="series-new"
                        ExternalErrorMessage="@ErrorMessage"
                        IsBusy="IsSaving"
                        OnSubmitRequested="SaveAsync" />
        </AppCard>
    </section>
</section>

@code {
    private SeriesFormModel Form { get; set; } = new();
    private bool IsSaving { get; set; }
    private string? ErrorMessage { get; set; }

    private async Task SaveAsync()
    {
        var media = new MediaItem();
        var series = new SeriesDetails();

        Form.ApplyTo(media, series);

        try
        {
            IsSaving = true;
            ErrorMessage = null;

            await LibraryState.AddAsync(media, null, series);
            ToastState.ShowSuccess(L["Show created."], L["The new show has been saved in your library."]);
            NavigationManager.NavigateTo(MediaRouteHelper.GetDetailsHref(media));
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
            ToastState.ShowError(L["Show could not be created."], exception.Message);
        }
        finally
        {
            IsSaving = false;
        }
    }
}
