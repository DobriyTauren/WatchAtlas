@page "/series/new"
@inject LibraryState LibraryState
@inject NavigationManager NavigationManager
@inject ToastState ToastState

<PageTitle>Create Series</PageTitle>

<section class="space-y-8">
    <PageHeader Eyebrow="New Series"
                Title="Add a series to your library."
                Subtitle="Set up the series, then add seasons and episodes whenever you're ready." />

    <section>
        <AppCard>
            <SeriesForm Model="Form"
                        SubmitLabel="Create Series"
                        CancelHref="/library"
                        FieldPrefix="series-new"
                        ExternalErrorMessage="@ErrorMessage"
                        IsBusy="IsSaving"
                        OnSubmitRequested="SaveAsync" />
        </AppCard>
    </section>
</section>

@code {
    private SeriesFormModel Form { get; set; } = new();
    private bool IsSaving { get; set; }
    private string? ErrorMessage { get; set; }

    private async Task SaveAsync()
    {
        var media = new MediaItem();
        var series = new SeriesDetails();

        Form.ApplyTo(media, series);

        try
        {
            IsSaving = true;
            ErrorMessage = null;

            await LibraryState.AddAsync(media, null, series);
            ToastState.ShowSuccess("Series created.", "The new series has been saved in your library.");
            NavigationManager.NavigateTo($"/series/{media.Id}");
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
            ToastState.ShowError("Series could not be created.", exception.Message);
        }
        finally
        {
            IsSaving = false;
        }
    }
}
