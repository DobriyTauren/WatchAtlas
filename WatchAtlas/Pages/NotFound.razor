@page "/not-found"
@layout MainLayout

<PageTitle>Not Found</PageTitle>

<section class="space-y-8">
    <PageHeader Eyebrow="404"
                Title="This page drifted out of orbit."
                Subtitle="The GitHub Pages fallback is configured, but this route still needs a matching page in the app." />

    <EmptyStateCard Badge="Routing"
                    Title="Nothing is mapped here yet."
                    Description="Try returning to the dashboard or jump into the library shell while the rest of the watch-tracking features are built out."
                    PrimaryLabel="Go Home"
                    PrimaryHref="/"
                    SecondaryLabel="Open Library"
                    SecondaryHref="/library" />
</section>
