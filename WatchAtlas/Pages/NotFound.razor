@page "/not-found"
@layout MainLayout
@inject NavigationManager NavigationManager

<PageTitle>@L["Not Found"]</PageTitle>

<section class="space-y-8">
    <PageHeader Eyebrow="404"
                Title="@L["This page could not be found."]"
                Subtitle="@L["The link may be outdated, or the page may not exist yet."]" />

    <EmptyStateCard Badge="@L["Routing"]"
                    Title="@L["Nothing to show here yet."]"
                    Description="@L["Go back home or open your library to keep browsing."]"
                    PrimaryLabel="@L["Go Home"]"
                    PrimaryHref="@NavigationManager.BaseUri"
                    SecondaryLabel="@L["Open Library"]"
                    SecondaryHref="library" />
</section>
