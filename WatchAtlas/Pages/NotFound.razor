@page "/not-found"
@layout MainLayout
@inject NavigationManager NavigationManager

<PageTitle>@L["Not Found"]</PageTitle>

<section class="space-y-8">
    <PageHeader Eyebrow="404"
                Title="@L["This page drifted out of orbit."]"
                Subtitle="@L["The GitHub Pages fallback is configured, but this route still needs a matching page in the app."]" />

    <EmptyStateCard Badge="@L["Routing"]"
                    Title="@L["Nothing is mapped here yet."]"
                    Description="@L["Try returning to the dashboard or jump into the library shell while the rest of the watch-tracking features are built out."]"
                    PrimaryLabel="@L["Go Home"]"
                    PrimaryHref="@NavigationManager.BaseUri"
                    SecondaryLabel="@L["Open Library"]"
                    SecondaryHref="library" />
</section>
