@page "/media/new"

<PageTitle>Add Media</PageTitle>

<section class="space-y-8">
    <PageHeader Eyebrow="New Media"
                Title="Create the entry flow for movies and series."
                Subtitle="The actual save flow lands in the next phase. For now, this page establishes the form layout, sections, and responsive card structure." />

    <section class="grid gap-4 xl:grid-cols-[1.25fr,0.9fr]">
        <article class="shell-card space-y-6 p-6 sm:p-8">
            <div class="grid gap-4 sm:grid-cols-2">
                <div class="space-y-2">
                    <label class="text-sm font-semibold text-text" for="media-type">Media Type</label>
                    <select id="media-type" class="input-shell" @bind="SelectedType">
                        <option value="@MediaType.Movie">Movie</option>
                        <option value="@MediaType.Series">Series</option>
                    </select>
                </div>

                <div class="space-y-2">
                    <label class="text-sm font-semibold text-text" for="media-title">Title</label>
                    <input id="media-title" class="input-shell" placeholder="Enter title" />
                </div>
            </div>

            <div class="space-y-2">
                <label class="text-sm font-semibold text-text" for="media-description">Description</label>
                <textarea id="media-description" class="input-shell min-h-36 resize-y" placeholder="Add a short description or notes"></textarea>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
                <div class="space-y-2">
                    <label class="text-sm font-semibold text-text" for="cover-url">Cover Image URL</label>
                    <input id="cover-url" class="input-shell" placeholder="https://example.com/cover.jpg" />
                </div>

                <div class="space-y-2">
                    <label class="text-sm font-semibold text-text" for="rating">Rating</label>
                    <input id="rating" class="input-shell" type="number" min="1" max="10" placeholder="1-10" />
                </div>
            </div>

            @if (SelectedType == MediaType.Movie)
            {
                <div class="soft-block-strong p-5">
                    <h2 class="text-xl">Movie Fields</h2>
                    <p class="mt-2 text-sm leading-7 text-muted">Duration, watched toggle, and watched date can slot in here with minimal restructuring.</p>
                </div>
            }
            else
            {
                <div class="soft-block-strong p-5">
                    <h2 class="text-xl">Series Builder</h2>
                    <p class="mt-2 text-sm leading-7 text-muted">Season and episode builders will connect here once we move into the CRUD phase.</p>
                </div>
            }

            <div class="flex flex-wrap gap-3">
                <button class="primary-button" type="button">Save in Next Phase</button>
                <a class="secondary-button" href="/library">Back to Library</a>
            </div>
        </article>

        <article class="shell-card p-6 sm:p-8">
            <div class="space-y-4">
                <h2 class="text-2xl">Form Roadmap</h2>
                <div class="space-y-4 text-sm leading-7 text-muted">
                    <p>Shared models are already in place for movies, series, seasons, and episodes.</p>
                    <p>Repository abstractions will let us plug this form into browser storage without rewriting the page.</p>
                    <p>Import/export and image handling already have interfaces reserved in the service layer.</p>
                </div>
            </div>
        </article>
    </section>
</section>

@code {
    private MediaType SelectedType { get; set; } = MediaType.Movie;
}
