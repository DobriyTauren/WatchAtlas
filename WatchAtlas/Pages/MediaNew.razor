@page "/media/new"
@inject LibraryState LibraryState
@inject NavigationManager NavigationManager

<PageTitle>@L["Add Media"]</PageTitle>

<section class="space-y-8">
    <PageHeader Eyebrow="@L["New Media"]"
                Title="@L["Add a movie or show to your library."]"
                Subtitle="@L["Fill in the details below and save it to your collection."]" />

    <section>
        <article class="shell-card p-6 sm:p-8">
            <MediaEditorForm Media="Media"
                             MovieDetails="Movie"
                             SeriesDetails="Series"
                             SubmitLabel="@L["Save Entry"]"
                             CancelHref="library"
                             FieldPrefix="media-new"
                             ExternalErrorMessage="@ErrorMessage"
                             IsBusy="IsSaving"
                             OnSubmitRequested="SaveAsync" />
        </article>
    </section>
</section>

@code {
    private MediaItem Media { get; set; } = new()
    {
        Type = MediaType.Movie
    };

    private WatchAtlas.Models.MovieDetails Movie { get; set; } = new();
    private SeriesDetails Series { get; set; } = new();
    private bool IsSaving { get; set; }
    private string? ErrorMessage { get; set; }

    private async Task SaveAsync()
    {
        try
        {
            IsSaving = true;
            ErrorMessage = null;

            await LibraryState.AddAsync(Media, Movie, Series);
            NavigationManager.NavigateTo(MediaRouteHelper.GetDetailsHref(Media));
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            IsSaving = false;
        }
    }
}
