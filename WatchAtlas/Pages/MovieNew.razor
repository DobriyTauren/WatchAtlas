@page "/movies/new"
@inject LibraryState LibraryState
@inject NavigationManager NavigationManager
@inject ToastState ToastState

<PageTitle>Create Movie</PageTitle>

<section class="space-y-8">
    <PageHeader Eyebrow="New Movie"
                Title="Add a movie to your library."
                Subtitle="Add the title, cover, and any details you want to remember." />

    <section>
        <AppCard>
            <MovieForm Model="Form"
                       SubmitLabel="Create Movie"
                       CancelHref="/library"
                       FieldPrefix="movie-new"
                       ExternalErrorMessage="@ErrorMessage"
                       IsBusy="IsSaving"
                       OnSubmitRequested="SaveAsync" />
        </AppCard>
    </section>
</section>

@code {
    private MovieFormModel Form { get; set; } = new();
    private bool IsSaving { get; set; }
    private string? ErrorMessage { get; set; }

    private async Task SaveAsync()
    {
        var media = new MediaItem();
        var movie = new WatchAtlas.Models.MovieDetails();

        Form.ApplyTo(media, movie);

        try
        {
            IsSaving = true;
            ErrorMessage = null;

            await LibraryState.AddAsync(media, movie, null);
            ToastState.ShowSuccess("Movie created.", "The new movie has been saved in your library.");
            NavigationManager.NavigateTo(MediaRouteHelper.GetDetailsHref(media));
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
            ToastState.ShowError("Movie could not be created.", exception.Message);
        }
        finally
        {
            IsSaving = false;
        }
    }
}
