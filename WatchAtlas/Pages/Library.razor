@page "/library"
@implements IDisposable
@inject FilterState FilterState
@inject LibraryState LibraryState
@inject SettingsState SettingsState

<PageTitle>Library</PageTitle>

<section class="space-y-8">
    <PageHeader Eyebrow="Library"
                Title="Browse your full watch collection."
                Subtitle="Search, filter, sort, and switch layouts across your full movie and series collection. The browsing view updates instantly from shared browser-backed state.">
    </PageHeader>

    @if (LibraryState.IsLoading && !LibraryState.IsLoaded)
    {
        <section class="space-y-4">
            <AppCard Class="space-y-5">
                <div class="grid gap-4 xl:grid-cols-[minmax(0,1.05fr),minmax(0,1fr),minmax(0,1fr),auto]">
                    <SkeletonBlock HeightClass="h-14" RadiusClass="rounded-[1.4rem]" />
                    <SkeletonBlock HeightClass="h-14" RadiusClass="rounded-[1.4rem]" />
                    <SkeletonBlock HeightClass="h-14" RadiusClass="rounded-[1.4rem]" />
                    <SkeletonBlock HeightClass="h-14" Class="w-28" RadiusClass="rounded-[1.4rem]" />
                </div>
                <SkeletonBlock HeightClass="h-20" RadiusClass="rounded-[1.75rem]" />
                <div class="flex items-center justify-between gap-4">
                    <div class="flex gap-3">
                        <SkeletonBlock HeightClass="h-12" Class="w-28" RadiusClass="rounded-full" />
                        <SkeletonBlock HeightClass="h-12" Class="w-32" RadiusClass="rounded-full" />
                    </div>
                    <SkeletonBlock HeightClass="h-12" Class="w-36" RadiusClass="rounded-full" />
                </div>
            </AppCard>

            <section class="grid gap-4 lg:grid-cols-2">
                <SkeletonCard Class="min-h-[16rem]" />
                <SkeletonCard Class="min-h-[16rem]" />
                <SkeletonCard Class="min-h-[16rem]" />
                <SkeletonCard Class="min-h-[16rem]" />
            </section>
        </section>
    }
    else
    {
    <AppCard Class="space-y-5">
        <div class="grid gap-4 xl:grid-cols-[minmax(0,1.05fr),minmax(0,1fr),minmax(0,1fr),auto] xl:items-end">
            <SortDropdown Id="library-sort"
                          Label="Sort"
                          Value="@SelectedSortKey"
                          ValueChanged="HandleSortChanged"
                          Options="@SortOptions" />

            <AppSelect TValue="string"
                       Id="library-genre-top"
                       Label="Genre"
                       Value="@SelectedGenreValue"
                       ValueChanged="HandleGenreChanged">
                <option value="">All genres</option>
                @foreach (var genre in AvailableGenres)
                {
                    <option value="@genre">@genre</option>
                }
            </AppSelect>

            <AppSelect TValue="string"
                       Id="library-series-top"
                       Label="Selected Series"
                       Value="@SelectedSeriesValue"
                       ValueChanged="HandleSeriesChanged">
                <option value="">All series</option>
                @foreach (var series in AvailableSeries)
                {
                    <option value="@series.Media.Id">@series.Media.Title</option>
                }
            </AppSelect>

            <div class="min-w-[8.5rem] pb-1 text-left xl:text-right">
                <p class="text-sm font-semibold text-text">@QueryResult.FilteredCount @VisibleItemsLabel</p>
                <p class="mt-1 text-sm text-muted">@VisibleItemsSummary</p>
            </div>
        </div>

        <FilterBar>
            <div class="space-y-3">
                <p class="text-sm font-semibold text-text">Quick Filters</p>
                <div class="flex flex-wrap gap-2">
                    <button class="@GetFilterButtonClass(FilterState.Options.MediaType is null && FilterState.Options.Status is null)" type="button" @onclick="() => SelectQuickFilter(null, null)">All Items</button>
                    <button class="@GetFilterButtonClass(FilterState.Options.MediaType == MediaType.Movie)" type="button" @onclick="() => SelectQuickFilter(MediaType.Movie, null)">Movies</button>
                    <button class="@GetFilterButtonClass(FilterState.Options.MediaType == MediaType.Series)" type="button" @onclick="() => SelectQuickFilter(MediaType.Series, null)">Series</button>
                    <button class="@GetFilterButtonClass(FilterState.Options.Status == WatchStatus.Completed)" type="button" @onclick="() => SelectQuickFilter(null, WatchStatus.Completed)">Completed</button>
                    <button class="@GetFilterButtonClass(FilterState.Options.Status == WatchStatus.InProgress)" type="button" @onclick="() => SelectQuickFilter(null, WatchStatus.InProgress)">In Progress</button>
                    <button class="@GetFilterButtonClass(FilterState.Options.Status == WatchStatus.NotStarted)" type="button" @onclick="() => SelectQuickFilter(null, WatchStatus.NotStarted)">Not Started</button>
                </div>
            </div>

            <div class="flex flex-wrap items-center justify-between gap-3 border-t border-border/60 pt-4">
                <div class="flex flex-wrap items-center gap-3">
                    <ViewModeToggle Value="@CurrentViewMode" ValueChanged="HandleViewModeChanged" />
                    <button class="@GetDirectionButtonClass()" type="button" @onclick="ToggleSortDirection">
                        @(FilterState.Options.Descending ? "Descending" : "Ascending")
                    </button>
                </div>

                <AppButton Variant="secondary" OnClick="ClearFiltersAsync">Reset Filters</AppButton>
            </div>
        </FilterBar>
    </AppCard>

    @if (QueryResult.TotalCount == 0)
    {
        <EmptyStateCard Badge="Library"
                        Title="Your library is still empty."
                        Description="Start by adding your first movie or series. Once it is saved, this page becomes your main browsing hub for search, filters, and progress tracking."
                        PrimaryLabel="Add First Entry"
                        PrimaryHref="media/new"
                        SecondaryLabel="Open Settings"
                        SecondaryHref="settings" />
    }
    else if (FilteredEntries.Count == 0)
    {
        <AppCard Class="text-center">
            <div class="mx-auto flex max-w-2xl flex-col items-center gap-4">
                <AppBadge>No Results</AppBadge>
                <h2 class="text-2xl">Nothing matches these filters.</h2>
                <p class="text-sm leading-7 text-muted sm:text-base">Try clearing one or two filters, broadening the search text, or switching the media type and status filters back to a wider view.</p>

                <div class="flex flex-wrap justify-center gap-3 pt-2">
                    <AppButton Variant="secondary" OnClick="ClearFiltersAsync">Reset Filters</AppButton>
                    <AppButton Href="media/new">Add New Item</AppButton>
                </div>
            </div>
        </AppCard>
    }
    else
    {
        @if (CurrentViewMode == LibraryViewMode.Grid)
        {
            <MediaGrid Entries="FilteredEntries" Dense="@SettingsState.Current.UseDenseLibraryGrid" />
        }
        else
        {
            <section class="space-y-4">
                @foreach (var entry in FilteredEntries)
                {
                    <MediaListItem Entry="entry" />
                }
            </section>
        }
    }
    }
</section>

@code {
    private static readonly IReadOnlyList<SortDropdown.SortDropdownOption> SortOptions = LibrarySortOptionHelper.Options
        .Select(option => new SortDropdown.SortDropdownOption
        {
            Key = option.Key,
            Label = option.Label
        })
        .ToList();

    private LibraryQueryResult QueryResult => FilterState.Apply(LibraryState.Entries);
    private IReadOnlyList<LibraryEntry> FilteredEntries => GetVisibleEntries();
    private IReadOnlyList<string> AvailableGenres => LibraryState.Entries
        .SelectMany(entry => entry.Media.Genres)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(genre => genre)
        .ToList();
    private IReadOnlyList<LibraryEntry> AvailableSeries => LibraryState.Entries
        .Where(entry => entry.Media.Type == MediaType.Series)
        .OrderBy(entry => entry.Media.Title)
        .ToList();
    private LibraryViewMode CurrentViewMode => SettingsState.Current.LibraryViewMode;
    private string SelectedGenreValue => FilterState.Options.Genre ?? string.Empty;
    private string SelectedSeriesValue => FilterState.Options.SeriesId?.ToString() ?? string.Empty;
    private string SelectedSortKey => LibrarySortOptionHelper.ToKey(FilterState.Options.SortBy, FilterState.Options.Descending);
    private string VisibleItemsLabel => QueryResult.FilteredCount == 1 ? "item" : "items";
    private string VisibleItemsSummary => QueryResult.TotalCount == QueryResult.FilteredCount
        ? "Everything is visible."
        : $"{QueryResult.FilteredCount} of {QueryResult.TotalCount} match.";

    protected override async Task OnInitializedAsync()
    {
        FilterState.Changed += HandleStateChanged;
        LibraryState.Changed += HandleStateChanged;
        SettingsState.Changed += HandleStateChanged;
        await LibraryState.EnsureLoadedAsync();
        await SettingsState.EnsureLoadedAsync();
        ApplyStoredSortDefaultsIfNeeded();
    }

    private Task HandleSortChanged(string value)
    {
        var option = LibrarySortOptionHelper.Parse(value);
        FilterState.SetSortBy(option.SortBy);
        FilterState.SetDescending(option.Descending);
        return Task.CompletedTask;
    }

    private Task HandleGenreChanged(string value)
    {
        FilterState.SetGenre(value);
        return Task.CompletedTask;
    }

    private Task HandleSeriesChanged(string value)
    {
        FilterState.SetSeriesId(Guid.TryParse(value, out var parsed) ? parsed : null);
        return Task.CompletedTask;
    }

    private void SelectQuickFilter(MediaType? mediaType, WatchStatus? status)
    {
        FilterState.SetMediaType(mediaType);
        FilterState.SetStatus(status);
    }

    private Task HandleViewModeChanged(LibraryViewMode mode)
        => SettingsState.UpdateLibraryViewModeAsync(mode);

    private Task ClearFiltersAsync(MouseEventArgs _)
    {
        FilterState.Reset(SettingsState.Current.DefaultLibrarySortBy, SettingsState.Current.DefaultLibrarySortDescending);
        return Task.CompletedTask;
    }

    private void ToggleSortDirection()
        => FilterState.SetDescending(!FilterState.Options.Descending);

    private string GetFilterButtonClass(bool isActive)
        => isActive ? "nav-chip nav-chip-active" : "nav-chip";

    private string GetDirectionButtonClass()
        => FilterState.Options.Descending ? "nav-chip nav-chip-active" : "nav-chip";

    private void ApplyStoredSortDefaultsIfNeeded()
    {
        var hasActiveFilters =
            !string.IsNullOrWhiteSpace(FilterState.Options.SearchTerm) ||
            !string.IsNullOrWhiteSpace(FilterState.Options.Genre) ||
            FilterState.Options.MediaType is not null ||
            FilterState.Options.Status is not null ||
            FilterState.Options.SeriesId is not null;

        var hasDefaultSort = FilterState.Options.SortBy == LibrarySortBy.UpdatedAt && FilterState.Options.Descending;
        if (!hasActiveFilters && hasDefaultSort)
        {
            FilterState.SetSortBy(SettingsState.Current.DefaultLibrarySortBy);
            FilterState.SetDescending(SettingsState.Current.DefaultLibrarySortDescending);
        }
    }

    private IReadOnlyList<LibraryEntry> GetVisibleEntries()
    {
        if (!SettingsState.Current.ShowCompletedItemsFirst)
        {
            return QueryResult.Items;
        }

        return QueryResult.Items
            .OrderByDescending(entry => WatchStatusHelper.GetStatus(entry) == WatchStatus.Completed)
            .ToList();
    }

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        FilterState.Changed -= HandleStateChanged;
        LibraryState.Changed -= HandleStateChanged;
        SettingsState.Changed -= HandleStateChanged;
    }
}
