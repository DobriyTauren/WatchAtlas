@page "/movies/{Id:guid}"
@inject LibraryState LibraryState
@inject NavigationManager NavigationManager
@inject ToastState ToastState

<PageTitle>@L["Movie Details"]</PageTitle>

<section class="space-y-8">
    @if (!IsReady)
    {
        <PageHeader Eyebrow="@L["Movie Details"]"
                    Title="@L["Loading movie."]"
                    Subtitle="@L["Opening the selected movie from your library."]" />
    }
    else if (Entry is null)
    {
        <PageHeader Eyebrow="@L["Movie Details"]"
                    Title="@L["We couldn't find this movie in your library."]"
                    Subtitle="@L["It may have been removed, or the link may be out of date."]" />

        <EmptyStateCard Badge="@L["Movie Details"]"
                        Title="@L["No movie found."]"
                        Description="@L["Create a movie first, then come back here to review its details and watch status."]"
                        PrimaryLabel="@L["Create Movie"]"
                        PrimaryHref="movies/new"
                        SecondaryLabel="@L["Return to Library"]"
                        SecondaryHref="library" />
    }
    else
    {
        <PageHeader Eyebrow="@L["Movie Details"]"
                    Title="@Entry.Media.Title"
                    Subtitle="@GetSubtitle()"
                    Actions="@ActionButtons" />

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="soft-block-strong border border-red-200/70 p-4 text-sm text-red-700">
                @ErrorMessage
            </div>
        }

        <section class="grid gap-4 xl:grid-cols-[0.95fr,1.15fr]">
            <AppCard Class="overflow-hidden p-0">
                @if (!string.IsNullOrWhiteSpace(Entry.Media.CoverImageUrl))
                {
                    <img src="@Entry.Media.CoverImageUrl"
                         alt="@($"{Entry.Media.Title} cover")"
                         class="h-full min-h-[24rem] w-full object-cover xl:min-h-[32rem]" />
                }
                else
                {
                    <div class="movie-cover-fallback h-full min-h-[24rem] xl:min-h-[32rem]">
                        <span class="movie-cover-fallback__badge">@L["Movie"]</span>
                        <h2 class="movie-cover-fallback__title">@Entry.Media.Title</h2>
                        <p class="movie-cover-fallback__copy">@L["Add a cover image from the edit page to make this movie feel complete."]</p>
                    </div>
                }
            </AppCard>

            <div class="space-y-4">
                <AppCard>
                    <div class="space-y-5">
                        <div class="flex flex-wrap gap-2">
                            <MediaTypeBadge Type="@MediaType.Movie" />
                            <MediaStatusBadge Status="@WatchStatusHelper.GetStatus(Entry)" />
                            @if (Entry.Media.PersonalRating is { } rating)
                            {
                                <span class="rating-pill">@rating/10</span>
                            }
                        </div>

                        <div class="grid gap-4 sm:grid-cols-2">
                            <div class="soft-block p-5">
                                <p class="text-sm font-semibold text-text">@L["Runtime"]</p>
                                <p class="mt-2 text-lg">@GetRuntime()</p>
                            </div>

                            <div class="soft-block p-5">
                                <p class="text-sm font-semibold text-text">@L["Watched Date"]</p>
                                <p class="mt-2 text-lg">@GetWatchedDate()</p>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Entry.Movie?.Universe))
                        {
                            <div class="soft-block p-4">
                                <p class="text-sm font-semibold text-text">@L["Universe"]</p>
                                <p class="mt-2 text-sm text-muted">@Entry.Movie.Universe</p>
                            </div>
                        }

                        @if (Entry.Media.Genres.Count > 0)
                        {
                            <div class="flex flex-wrap gap-2">
                                @foreach (var genre in Entry.Media.Genres)
                                {
                                    <AppBadge Variant="outline">@genre</AppBadge>
                                }
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(Entry.Media.Description))
                        {
                            <div class="space-y-2">
                                <h2 class="text-xl">@L["Description"]</h2>
                                <p class="text-sm leading-7 text-muted">@Entry.Media.Description</p>
                            </div>
                        }
                    </div>
                </AppCard>

                <AppCard>
                    <div class="grid gap-4 sm:grid-cols-2">
                        <div class="soft-block-strong p-5">
                            <p class="text-sm font-semibold text-text">@L["Created"]</p>
                            <p class="mt-2 text-lg">@Entry.Media.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</p>
                        </div>

                        <div class="soft-block-strong p-5">
                            <p class="text-sm font-semibold text-text">@L["Updated"]</p>
                            <p class="mt-2 text-lg">@Entry.Media.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy")</p>
                        </div>
                    </div>
                </AppCard>
            </div>
        </section>

        <AppModal IsOpen="@IsDeleteModalOpen"
                  Title="@L["Delete this movie?"]"
                  Description="@L["This removes the movie from your library on this device."]"
                  OnClose="CloseDeleteModalAsync">
            <ChildContent>
                <p class="text-sm leading-7 text-muted">
                    @L.Format("\"{0}\" will be removed from the library immediately.", Entry.Media.Title)
                </p>
            </ChildContent>
            <Footer>
                <AppButton Variant="secondary" Disabled="@IsDeleting" OnClick="CloseDeleteModalButtonAsync">@L["Cancel"]</AppButton>
                <AppButton IsLoading="@IsDeleting" OnClick="ConfirmDeleteAsync">@L["Delete Movie"]</AppButton>
            </Footer>
        </AppModal>
    }
</section>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private LibraryEntry? Entry { get; set; }
    private bool IsReady { get; set; }
    private bool IsDeleteModalOpen { get; set; }
    private bool IsDeleting { get; set; }
    private string? ErrorMessage { get; set; }

    private RenderFragment ActionButtons => @<div class="flex flex-wrap gap-3">
        <AppButton Href="@($"movies/{Id}/edit")" Variant="secondary">@L["Edit Movie"]</AppButton>
        <AppButton OnClick="OpenDeleteModalAsync">@L["Delete Movie"]</AppButton>
    </div>;

    protected override async Task OnParametersSetAsync()
    {
        IsReady = false;
        IsDeleteModalOpen = false;
        ErrorMessage = null;

        await LibraryState.EnsureLoadedAsync();
        var entry = LibraryState.GetById(Id);
        Entry = entry?.Media.Type == MediaType.Movie ? entry : null;
        IsReady = true;
    }

    private string GetSubtitle()
    {
        if (Entry is null)
        {
            return string.Empty;
        }

        return Entry.Movie?.IsWatched == true
            ? L["This movie is marked as watched in your library."]
            : L["This movie is saved in your library, and you can update its progress anytime."];
    }

    private string GetRuntime()
    {
        var runtimeMinutes = Entry?.Movie?.DurationMinutes;
        return runtimeMinutes.HasValue && runtimeMinutes.Value > 0
            ? runtimeMinutes.Value.ToReadableDuration()
            : L["Not tracked yet"];
    }

    private string GetWatchedDate()
        => Entry?.Movie?.WatchedDate?.ToLocalTime().ToString("dd MMM yyyy") ?? L["Not set"];

    private Task OpenDeleteModalAsync(MouseEventArgs _)
    {
        IsDeleteModalOpen = true;
        return Task.CompletedTask;
    }

    private Task CloseDeleteModalButtonAsync(MouseEventArgs _)
        => CloseDeleteModalAsync();

    private Task CloseDeleteModalAsync()
    {
        IsDeleteModalOpen = false;
        return Task.CompletedTask;
    }

    private async Task ConfirmDeleteAsync(MouseEventArgs _)
    {
        if (Entry is null)
        {
            return;
        }

        var deletedTitle = Entry.Media.Title;

        try
        {
            IsDeleting = true;
            ErrorMessage = null;
            await LibraryState.DeleteAsync(Entry.Media.Id);
            ToastState.ShowSuccess(L["Movie deleted."], L.Format("\"{0}\" was removed from your library.", deletedTitle));
            NavigationManager.NavigateTo("library");
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
            ToastState.ShowError(L["Movie could not be deleted."], exception.Message);
        }
        finally
        {
            IsDeleting = false;
            IsDeleteModalOpen = false;
        }
    }
}
