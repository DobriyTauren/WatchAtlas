@page "/movies/{Id:guid}"
@inject LibraryState LibraryState
@inject NavigationManager NavigationManager

<PageTitle>Movie Details</PageTitle>

<section class="space-y-8">
    @if (!IsReady)
    {
        <PageHeader Eyebrow="Movie Details"
                    Title="Loading movie details."
                    Subtitle="Reading the selected movie from browser storage." />
    }
    else if (Entry is null)
    {
        <PageHeader Eyebrow="Movie Details"
                    Title="This movie is not in the library yet."
                    Subtitle="The details route is ready, but the requested movie was not found in browser storage." />

        <EmptyStateCard Badge="Movie Details"
                        Title="No movie found."
                        Description="Create a movie first, then return here to review metadata, watch status, and notes."
                        PrimaryLabel="Create Movie"
                        PrimaryHref="/movies/new"
                        SecondaryLabel="Return to Library"
                        SecondaryHref="/library" />
    }
    else
    {
        <PageHeader Eyebrow="Movie Details"
                    Title="@Entry.Media.Title"
                    Subtitle="@GetSubtitle()"
                    Actions="@ActionButtons" />

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="soft-block-strong border border-red-200/70 p-4 text-sm text-red-700">
                @ErrorMessage
            </div>
        }

        <section class="grid gap-4 xl:grid-cols-[0.95fr,1.15fr]">
            <AppCard Class="overflow-hidden">
                @if (!string.IsNullOrWhiteSpace(Entry.Media.CoverImageUrl))
                {
                    <img src="@Entry.Media.CoverImageUrl"
                         alt="@($"{Entry.Media.Title} cover")"
                         class="h-80 w-full rounded-3xl object-cover" />
                }
                else
                {
                    <div class="movie-cover-fallback">
                        <span class="movie-cover-fallback__badge">Movie</span>
                        <h2 class="movie-cover-fallback__title">@Entry.Media.Title</h2>
                        <p class="movie-cover-fallback__copy">Add a cover image from the edit page to make this movie card feel more complete.</p>
                    </div>
                }
            </AppCard>

            <div class="space-y-4">
                <AppCard>
                    <div class="space-y-5">
                        <div class="flex flex-wrap gap-2">
                            <MediaTypeBadge Type="@MediaType.Movie" />
                            <MediaStatusBadge Status="@WatchStatusHelper.GetStatus(Entry)" />
                            @if (Entry.Media.PersonalRating is { } rating)
                            {
                                <span class="rating-pill">@rating/10</span>
                            }
                        </div>

                        <div class="grid gap-4 sm:grid-cols-2">
                            <div class="soft-block p-5">
                                <p class="text-sm font-semibold text-text">Runtime</p>
                                <p class="mt-2 text-lg">@GetRuntime()</p>
                            </div>

                            <div class="soft-block p-5">
                                <p class="text-sm font-semibold text-text">Watched Date</p>
                                <p class="mt-2 text-lg">@GetWatchedDate()</p>
                            </div>
                        </div>

                        @if (Entry.Media.Genres.Count > 0)
                        {
                            <div class="flex flex-wrap gap-2">
                                @foreach (var genre in Entry.Media.Genres)
                                {
                                    <AppBadge Variant="outline">@genre</AppBadge>
                                }
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(Entry.Media.Description))
                        {
                            <div class="space-y-2">
                                <h2 class="text-xl">Description</h2>
                                <p class="text-sm leading-7 text-muted">@Entry.Media.Description</p>
                            </div>
                        }
                    </div>
                </AppCard>

                <AppCard>
                    <div class="space-y-4">
                        <h2 class="text-2xl">Notes</h2>
                        <p class="text-sm leading-7 text-muted">
                            @(string.IsNullOrWhiteSpace(Entry.Media.Notes)
                                ? "No notes have been added for this movie yet."
                                : Entry.Media.Notes)
                        </p>

                        <div class="grid gap-4 sm:grid-cols-2">
                            <div class="soft-block-strong p-5">
                                <p class="text-sm font-semibold text-text">Created</p>
                                <p class="mt-2 text-lg">@Entry.Media.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</p>
                            </div>

                            <div class="soft-block-strong p-5">
                                <p class="text-sm font-semibold text-text">Updated</p>
                                <p class="mt-2 text-lg">@Entry.Media.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy")</p>
                            </div>
                        </div>
                    </div>
                </AppCard>
            </div>
        </section>

        <AppModal IsOpen="@IsDeleteModalOpen"
                  Title="Delete this movie?"
                  Description="This permanently removes the movie and its stored watch details from browser storage."
                  OnClose="CloseDeleteModalAsync">
            <ChildContent>
                <p class="text-sm leading-7 text-muted">
                    <strong>@Entry.Media.Title</strong> will be removed from the library immediately.
                </p>
            </ChildContent>
            <Footer>
                <AppButton Variant="secondary" Disabled="@IsDeleting" OnClick="CloseDeleteModalButtonAsync">Cancel</AppButton>
                <AppButton Disabled="@IsDeleting" OnClick="ConfirmDeleteAsync">Delete Movie</AppButton>
            </Footer>
        </AppModal>
    }
</section>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private LibraryEntry? Entry { get; set; }
    private bool IsReady { get; set; }
    private bool IsDeleteModalOpen { get; set; }
    private bool IsDeleting { get; set; }
    private string? ErrorMessage { get; set; }

    private RenderFragment ActionButtons => @<div class="flex flex-wrap gap-3">
        <AppButton Href="@($"/movies/{Id}/edit")" Variant="secondary">Edit Movie</AppButton>
        <AppButton OnClick="OpenDeleteModalAsync">Delete Movie</AppButton>
    </div>;

    protected override async Task OnParametersSetAsync()
    {
        IsReady = false;
        IsDeleteModalOpen = false;
        ErrorMessage = null;

        await LibraryState.EnsureLoadedAsync();
        var entry = LibraryState.GetById(Id);
        Entry = entry?.Media.Type == MediaType.Movie ? entry : null;
        IsReady = true;
    }

    private string GetSubtitle()
    {
        if (Entry is null)
        {
            return string.Empty;
        }

        return Entry.Movie?.IsWatched == true
            ? "Watched movie details, runtime, and notes are stored locally and ready to edit."
            : "This movie is in your library and ready for watch progress, notes, and metadata updates.";
    }

    private string GetRuntime()
    {
        var runtimeMinutes = Entry?.Movie?.DurationMinutes;
        return runtimeMinutes.HasValue && runtimeMinutes.Value > 0
            ? runtimeMinutes.Value.ToReadableDuration()
            : "Not tracked yet";
    }

    private string GetWatchedDate()
        => Entry?.Movie?.WatchedDate?.ToLocalTime().ToString("dd MMM yyyy") ?? "Not set";

    private Task OpenDeleteModalAsync(MouseEventArgs _)
    {
        IsDeleteModalOpen = true;
        return Task.CompletedTask;
    }

    private Task CloseDeleteModalButtonAsync(MouseEventArgs _)
        => CloseDeleteModalAsync();

    private Task CloseDeleteModalAsync()
    {
        IsDeleteModalOpen = false;
        return Task.CompletedTask;
    }

    private async Task ConfirmDeleteAsync(MouseEventArgs _)
    {
        if (Entry is null)
        {
            return;
        }

        try
        {
            IsDeleting = true;
            ErrorMessage = null;
            await LibraryState.DeleteAsync(Entry.Media.Id);
            NavigationManager.NavigateTo("/library");
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            IsDeleting = false;
            IsDeleteModalOpen = false;
        }
    }
}
