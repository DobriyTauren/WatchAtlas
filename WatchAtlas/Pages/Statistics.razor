@page "/statistics"
@implements IDisposable
@inject LibraryState LibraryState
@inject IStatisticsService StatisticsService
@using WatchAtlas.Extensions

<PageTitle>Statistics</PageTitle>

<section class="space-y-8">
    <PageHeader Eyebrow="Statistics"
                Title="A clear overview of your watch progress."
                Subtitle="The statistics service now centralizes totals, watch-time summaries, completion breakdowns, and ranked series or season views so analytics stay consistent everywhere." />

    <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        <StatCard Title="Movies Watched"
                  Value="@Stats.WatchedMovies.ToString()"
                  Caption="@($"{Stats.WatchedMovies} of {Stats.TotalMovies} movies are marked watched.")"
                  ChipLabel="Movies" />
        <StatCard Title="Series Added"
                  Value="@Stats.TotalSeries.ToString()"
                  Caption="@($"{Stats.CompletedSeries} completed, {Stats.InProgressSeries} in progress.")"
                  ChipLabel="Series" />
        <StatCard Title="Episodes Watched"
                  Value="@Stats.WatchedEpisodes.ToString()"
                  Caption="@($"{Stats.WatchedEpisodes}/{Stats.TotalEpisodes} tracked episodes watched.")"
                  ChipLabel="Episodes" />
        <StatCard Title="Total Watch Time"
                  Value="@Stats.TotalWatchTimeMinutes.ToReadableDuration()"
                  Caption="Sum of watched movie and episode runtime."
                  ChipLabel="Runtime"
                  ChipVariant="success" />
    </section>

    <section class="grid gap-4 xl:grid-cols-[1.15fr,1fr]">
        <GlobalStatsPanel Stats="Stats" />
        <WatchTimeSummaryPanel Summary="WatchTime" />
    </section>

    <section class="space-y-4">
        <SectionHeader Eyebrow="Rankings"
                       Title="Top series by watched duration."
                       Description="Series ordered by the amount of watched runtime already logged in the library." />

        @if (TopSeriesByDuration.Count == 0)
        {
            <AppCard>
                <p class="text-sm leading-7 text-muted">No tracked series runtime yet. Add a series with seasons and watched episodes to see rankings here.</p>
            </AppCard>
        }
        else
        {
            <section class="grid gap-4 xl:grid-cols-3">
                @foreach (var series in TopSeriesByDuration)
                {
                    <SeriesStatsCard Statistics="series" />
                }
            </section>
        }
    </section>

    <section class="space-y-4">
        <SectionHeader Eyebrow="Completion"
                       Title="Most completed series."
                       Description="Entries ranked by completion percentage, then by watched episode count." />

        @if (MostCompletedSeries.Count == 0)
        {
            <AppCard>
                <p class="text-sm leading-7 text-muted">No series progress to compare yet. Once episodes are tracked, completion standings will appear here.</p>
            </AppCard>
        }
        else
        {
            <section class="grid gap-4 xl:grid-cols-3">
                @foreach (var series in MostCompletedSeries)
                {
                    <SeriesStatsCard Statistics="series" />
                }
            </section>
        }
    </section>

    <section class="space-y-4">
        <SectionHeader Eyebrow="Seasons"
                       Title="Top seasons by watched runtime."
                       Description="Season totals are calculated from episode data and ranked across the whole library." />

        @if (TopSeasonsByDuration.Count == 0)
        {
            <AppCard>
                <p class="text-sm leading-7 text-muted">No season runtime has been logged yet. Mark episodes as watched to populate these cards.</p>
            </AppCard>
        }
        else
        {
            <section class="grid gap-4 xl:grid-cols-3">
                @foreach (var season in TopSeasonsByDuration)
                {
                    <SeasonStatsCard Statistics="season" />
                }
            </section>
        }
    </section>
</section>

@code {
    private GlobalStatistics Stats => StatisticsService.CalculateGlobalStatistics(LibraryState.Entries);
    private WatchTimeSummary WatchTime => StatisticsService.CalculateWatchTimeSummary(LibraryState.Entries);
    private IReadOnlyList<SeriesStatistics> TopSeriesByDuration => StatisticsService.GetTopSeriesByWatchTime(LibraryState.Entries, 3);
    private IReadOnlyList<SeriesStatistics> MostCompletedSeries => StatisticsService.GetMostCompletedSeries(LibraryState.Entries, 3);
    private IReadOnlyList<SeasonStatistics> TopSeasonsByDuration => StatisticsService.GetTopSeasonsByWatchTime(LibraryState.Entries, 3);

    protected override async Task OnInitializedAsync()
    {
        LibraryState.Changed += HandleLibraryChanged;
        await LibraryState.EnsureLoadedAsync();
    }

    private void HandleLibraryChanged()
        => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        LibraryState.Changed -= HandleLibraryChanged;
    }
}
