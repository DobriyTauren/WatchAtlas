@page "/statistics"
@implements IDisposable
@inject LibraryState LibraryState
@inject IStatisticsService StatisticsService
@using WatchAtlas.Extensions

<PageTitle>@L["Statistics"]</PageTitle>

<section class="space-y-8">
    @if (LibraryState.IsLoading && !LibraryState.IsLoaded)
    {
        <PageHeader Eyebrow="@L["Statistics"]"
                    Title="@L["Loading your watch progress."]"
                    Subtitle="@L["Crunching totals, watch-time summaries, and completion breakdowns from browser storage."]" />

        <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <SkeletonCard />
            <SkeletonCard />
            <SkeletonCard />
            <SkeletonCard />
        </section>

        <section class="grid gap-4 xl:grid-cols-[1.15fr,1fr]">
            <SkeletonCard Class="min-h-[20rem]" />
            <SkeletonCard Class="min-h-[20rem]" />
        </section>
    }
    else
    {
        <PageHeader Eyebrow="@L["Statistics"]"
                    Title="@L["A clear overview of your watch progress."]" />

        <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <StatCard Title="@L["Movies Watched"]"
                      Value="@Stats.WatchedMovies.ToString()"
                      Caption="@L.Format("{0} of {1} movies are marked watched.", Stats.WatchedMovies, Stats.TotalMovies)"
                      ChipLabel="@L["Movies"]" />
            <StatCard Title="@L["Shows Added"]"
                      Value="@Stats.TotalSeries.ToString()"
                      Caption="@L.Format("{0} completed, {1} in progress.", Stats.CompletedSeries, Stats.InProgressSeries)"
                      ChipLabel="@L["Shows"]" />
            <StatCard Title="@L["Episodes Watched"]"
                      Value="@Stats.WatchedEpisodes.ToString()"
                      Caption="@L.Format("{0}/{1} tracked episodes watched.", Stats.WatchedEpisodes, Stats.TotalEpisodes)"
                      ChipLabel="@L["Episodes"]" />
            <StatCard Title="@L["Total Watch Time"]"
                      Value="@Stats.TotalWatchTimeMinutes.ToReadableDuration()"
                      Caption="@L["Sum of watched movie and episode runtime."]"
                      ChipLabel="@L["Runtime"]"
                      ChipVariant="success" />
        </section>

        <section class="grid gap-4 xl:grid-cols-[1.15fr,1fr]">
            <GlobalStatsPanel Stats="Stats" />
            <WatchTimeSummaryPanel Summary="WatchTime" />
        </section>

        <section class="space-y-4">
        <SectionHeader Eyebrow="@L["Rankings"]"
                       Title="@L["Top shows by watched duration."]"
                       Description="@L["Shows ordered by the amount of watched runtime already logged in the library."]" />

        @if (TopSeriesByDuration.Count == 0)
        {
            <AppCard>
                <p class="text-sm leading-7 text-muted">@L["No tracked shows runtime yet. Add a show with seasons and watched episodes to see rankings here."]</p>
            </AppCard>
        }
        else
        {
            <section class="grid gap-4 xl:grid-cols-3">
                @foreach (var series in TopSeriesByDuration)
                {
                    <SeriesStatsCard Statistics="series" />
                }
            </section>
        }
        </section>

        <section class="space-y-4">
        <SectionHeader Eyebrow="@L["Episodes"]"
                       Title="@L["Most episodes watched."]"
                       Description="@L["Shows ranked by watched episode count, then by logged watch time."]" />

        @if (MostEpisodesWatchedSeries.Count == 0)
        {
            <AppCard>
                <p class="text-sm leading-7 text-muted">@L["No watched episodes yet. Start tracking episode progress to populate this ranking."]</p>
            </AppCard>
        }
        else
        {
            <section class="grid gap-4 xl:grid-cols-3">
                @foreach (var series in MostEpisodesWatchedSeries)
                {
                    <SeriesStatsCard Statistics="series" />
                }
            </section>
        }
        </section>

        <section class="space-y-4">
        <SectionHeader Eyebrow="@L["In Progress"]"
                       Title="@L["Currently watching."]"
                       Description="@L["Shows that are in progress right now, ranked by watched episodes and active watch time."]" />

        @if (CurrentlyWatchingSeries.Count == 0)
        {
            <AppCard>
                <p class="text-sm leading-7 text-muted">@L["No in-progress shows yet. Once a show is partly watched, it will show up here."]</p>
            </AppCard>
        }
        else
        {
            <section class="grid gap-4 xl:grid-cols-3">
                @foreach (var series in CurrentlyWatchingSeries)
                {
                    <SeriesStatsCard Statistics="series" />
                }
            </section>
        }
        </section>

        <section class="space-y-4">
        <SectionHeader Eyebrow="@L["Genres"]"
                       Title="@L["Watch time by genre."]"
                       Description="@L["Watched movie runtime and watched episode runtime grouped by library genres."]" />

        @if (TopGenresByWatchTime.Count == 0)
        {
            <AppCard>
                <p class="text-sm leading-7 text-muted">@L["No watched runtime has been matched to genres yet. Add genres and watched entries to see the breakdown."]</p>
            </AppCard>
        }
        else
        {
            <section class="grid gap-4 xl:grid-cols-3">
                @foreach (var genre in TopGenresByWatchTime)
                {
                    <GenreWatchTimeCard Statistics="genre" />
                }
            </section>
        }
        </section>

        <section class="space-y-4">
        <SectionHeader Eyebrow="@L["Universes"]"
                       Title="@L["Watch time by universe."]"
                       Description="@L["Watched movie runtime and watched episode runtime grouped by universe."]" />

        @if (TopUniversesByWatchTime.Count == 0)
        {
            <AppCard>
                <p class="text-sm leading-7 text-muted">@L["No watched runtime has been matched to universes yet. Add universes to movies or shows and track watched progress to see the breakdown."]</p>
            </AppCard>
        }
        else
        {
            <section class="grid gap-4 xl:grid-cols-3">
                @foreach (var universe in TopUniversesByWatchTime)
                {
                    <UniverseWatchTimeCard Statistics="universe" />
                }
            </section>
        }
        </section>

        <section class="space-y-4">
        <SectionHeader Eyebrow="@L["Seasons"]"
                       Title="@L["Top seasons by watched runtime."]"
                       Description="@L["Season totals are calculated from episode data and ranked across the whole library."]" />

        @if (TopSeasonsByDuration.Count == 0)
        {
            <AppCard>
                <p class="text-sm leading-7 text-muted">@L["No season runtime has been logged yet. Mark episodes as watched to populate these cards."]</p>
            </AppCard>
        }
        else
        {
            <section class="grid gap-4 xl:grid-cols-3">
                @foreach (var season in TopSeasonsByDuration)
                {
                    <SeasonStatsCard Statistics="season" />
                }
            </section>
        }
        </section>
    }
</section>

@code {
    private GlobalStatistics Stats => StatisticsService.CalculateGlobalStatistics(LibraryState.Entries);
    private WatchTimeSummary WatchTime => StatisticsService.CalculateWatchTimeSummary(LibraryState.Entries);
    private IReadOnlyList<SeriesStatistics> TopSeriesByDuration => StatisticsService.GetTopSeriesByWatchTime(LibraryState.Entries, 3);
    private IReadOnlyList<SeriesStatistics> MostEpisodesWatchedSeries => StatisticsService.GetMostEpisodesWatchedSeries(LibraryState.Entries, 3);
    private IReadOnlyList<SeriesStatistics> CurrentlyWatchingSeries => StatisticsService.GetCurrentlyWatchingSeries(LibraryState.Entries, 3);
    private IReadOnlyList<GenreWatchTimeStatistics> TopGenresByWatchTime => StatisticsService.GetTopGenresByWatchTime(LibraryState.Entries, 3);
    private IReadOnlyList<UniverseWatchTimeStatistics> TopUniversesByWatchTime => StatisticsService.GetTopUniversesByWatchTime(LibraryState.Entries, 3);
    private IReadOnlyList<SeasonStatistics> TopSeasonsByDuration => StatisticsService.GetTopSeasonsByWatchTime(LibraryState.Entries, 3);
    protected override async Task OnInitializedAsync()
    {
        LibraryState.Changed += HandleLibraryChanged;
        await LibraryState.EnsureLoadedAsync();
    }

    private void HandleLibraryChanged()
        => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        LibraryState.Changed -= HandleLibraryChanged;
    }
}
