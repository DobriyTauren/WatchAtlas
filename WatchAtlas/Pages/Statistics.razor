@page "/statistics"
@inject LibraryState LibraryState
@inject IStatisticsService StatisticsService
@using WatchAtlas.Extensions

<PageTitle>Statistics</PageTitle>

<section class="space-y-8">
    <PageHeader Eyebrow="Statistics"
                Title="A clear overview of your watch progress."
                Subtitle="The statistics service already centralizes watch totals, progress percentages, and total runtime so future features can reuse the same calculations." />

    <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        <StatTile Title="Movies Added" Value="@Stats.TotalMovies.ToString()" Caption="All movie entries in your library." ChipLabel="Catalog" />
        <StatTile Title="Completed Series" Value="@Stats.CompletedSeries.ToString()" Caption="Series with every tracked episode watched." ChipLabel="Series" />
        <StatTile Title="Episodes Watched" Value="@Stats.WatchedEpisodes.ToString()" Caption="@($"{Stats.WatchedEpisodes}/{Stats.TotalEpisodes} tracked episodes completed.")" ChipLabel="Episodes" />
        <StatTile Title="Total Watch Time" Value="@Stats.TotalWatchTimeMinutes.ToReadableDuration()" Caption="Sum of watched movie and episode runtimes." ChipLabel="Runtime" />
    </section>

    <section class="grid gap-4 xl:grid-cols-[1.2fr,1fr]">
        <article class="shell-card p-6 sm:p-8">
            <h2 class="text-2xl">Global Overview</h2>
            <div class="mt-6 grid gap-4 sm:grid-cols-2">
                <div class="soft-block-strong p-5">
                    <p class="text-sm font-semibold text-text">Series Completion</p>
                    <p class="mt-2 text-3xl">@Stats.AverageSeriesCompletionPercent.ToString("0")%</p>
                    <p class="mt-2 text-sm text-muted">Average progress across all series entries.</p>
                </div>

                <div class="soft-block-strong p-5">
                    <p class="text-sm font-semibold text-text">Watched Movies</p>
                    <p class="mt-2 text-3xl">@Stats.WatchedMovies</p>
                    <p class="mt-2 text-sm text-muted">Movie progress will later connect directly to local storage persistence.</p>
                </div>
            </div>
        </article>

        <article class="shell-card p-6 sm:p-8">
            <h2 class="text-2xl">Why It Matters</h2>
            <div class="mt-5 space-y-4 text-sm leading-7 text-muted">
                <p>The stats page is already pulling from a single service, which keeps future dashboard, library cards, and detailed series pages consistent.</p>
                <p>When we wire in local storage next, this page should start reflecting real values without changing the page-level markup very much.</p>
            </div>
        </article>
    </section>
</section>

@code {
    private GlobalStatistics Stats => StatisticsService.CalculateGlobalStatistics(LibraryState.Entries);

    protected override async Task OnInitializedAsync()
    {
        await LibraryState.EnsureLoadedAsync();
    }
}
