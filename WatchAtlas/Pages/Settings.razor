@page "/settings"
@inject SettingsState SettingsState

<PageTitle>Settings</PageTitle>

<section class="space-y-8">
    <PageHeader Eyebrow="Settings"
                Title="Tune the app shell and shared presentation layer."
                Subtitle="Phase 3 turns the existing theme groundwork into a persisted design system with reusable UI primitives and live theme switching." />

    <section class="grid gap-4 xl:grid-cols-[1.2fr,1fr]">
        <AppCard>
            <div class="flex flex-col gap-6">
                <SectionHeader Eyebrow="Theme System"
                               Title="Themes"
                               Description="Theme changes now apply live, persist in browser settings, and update the root document theme before Blazor finishes hydrating." />

                <ThemeSwitcher ShowCurrentButton="false" />
            </div>
        </AppCard>

        <AppCard>
            <div class="space-y-5">
                <SectionHeader Eyebrow="Design System"
                               Title="Architecture Notes"
                               Description="The design layer now reuses token-driven components instead of repeating raw utility combinations across pages." />
                <div class="space-y-4 text-sm leading-7 text-muted">
                    <p><span class="font-semibold text-text">Storage:</span> settings and media both persist through browser storage repositories, so theme and library preferences survive reloads.</p>
                    <p><span class="font-semibold text-text">Hosting:</span> the app uses a project-site base path and an SPA fallback page for GitHub Pages compatibility.</p>
                    <p><span class="font-semibold text-text">State:</span> theme, library, filters, and settings live in scoped services instead of a heavier external state library.</p>
                    <p><span class="font-semibold text-text">Components:</span> buttons, fields, cards, badges, progress, modals, and theme selection now share one visual language.</p>
                </div>
            </div>
        </AppCard>
    </section>
</section>

@code {
    protected override async Task OnInitializedAsync()
    {
        await SettingsState.EnsureLoadedAsync();
    }
}
