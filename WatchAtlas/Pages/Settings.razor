@page "/settings"
@implements IDisposable
@using System.IO
@inject IImportExportService ImportExportService
@inject IJSRuntime JsRuntime
@inject LibraryState LibraryState
@inject SettingsState SettingsState
@inject ThemeState ThemeState
@inject FilterState FilterState
@inject ToastState ToastState

<PageTitle>@L["Settings"]</PageTitle>

<section class="space-y-8">
    <PageHeader Eyebrow="@L["Settings"]"
                Title="@L["Choose your language, backup your library, and manage your data."]"
                Subtitle="@L["Adjust the app to your liking, keep a backup, or clear everything on this device."]" />

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="soft-block border border-red-200/70 p-4 text-sm text-red-700">
            @ErrorMessage
        </div>
    }

    <section class="grid gap-4 xl:grid-cols-[1.15fr,1fr]">
        <AppCard>
            <div class="space-y-6">
                <SectionHeader Eyebrow="@L["Appearance"]"
                               Title="@L["Theme and library defaults"]"
                               Description="@L["Adjust how the app looks and how the library opens."]" />

                <div class="space-y-4">
                    <div class="soft-block p-5">
                        <p class="text-sm font-semibold text-text">@L["Theme"]</p>
                        <p class="mt-2 text-sm leading-7 text-muted">@L["Switch between light, dark, and pastel themes. Your choice is saved automatically."]</p>
                        <div class="mt-4">
                            <ThemeSwitcher ShowCurrentButton="false" />
                        </div>
                    </div>

                    <div class="grid gap-4 md:grid-cols-[1fr,1.1fr]">
                        <div class="soft-block p-5">
                            <p class="text-sm font-semibold text-text">@L["Preferred library view"]</p>
                            <p class="mt-2 text-sm leading-7 text-muted">@L["Choose the browsing layout that opens by default on the library page."]</p>
                            <div class="mt-4">
                                <ViewModeToggle Value="@SettingsState.Current.LibraryViewMode" ValueChanged="HandleViewModeChanged" />
                            </div>
                        </div>

                        <div class="soft-block p-5">
                            <SortDropdown Id="settings-default-sort"
                                          Label="@L["Default library sort"]"
                                          Value="@SelectedDefaultSortKey"
                                          ValueChanged="HandleDefaultSortChanged"
                                          Options="@SortOptions" />
                            <p class="mt-3 text-sm leading-7 text-muted">@L["Used when the library opens or when you reset active filters."]</p>
                        </div>
                    </div>

                    <div class="soft-block p-5">
                        <AppSelect TValue="AppLanguage"
                                   Id="settings-language"
                                   Label="@L["App language"]"
                                   Value="@SelectedLanguage"
                                   ValueChanged="HandleLanguageChanged">
                            <option value="@AppLanguage.English">@L["English"]</option>
                            <option value="@AppLanguage.Russian">@L["Russian"]</option>
                        </AppSelect>
                        <p class="mt-3 text-sm leading-7 text-muted">@L["WatchAtlas uses your browser language the first time you open it. You can change it here anytime."]</p>
                    </div>
                </div>
            </div>
        </AppCard>

        <AppCard>
            <div class="space-y-6">
                <SectionHeader Eyebrow="@L["Backup"]"
                               Title="@L["Export and restore your library"]"
                               Description="@L["Download a backup file with your library and settings, or restore everything from a saved file."]" />

                <div class="soft-block p-5">
                    <p class="text-sm font-semibold text-text">@L["Save a backup of your library"]</p>
                    <p class="mt-2 text-sm leading-7 text-muted">@L["Download a backup of your library and settings."]</p>
                    <div class="mt-4 flex flex-wrap gap-3">
                        <AppButton IsLoading="@IsExporting" OnClick="ExportBackupAsync">
                            @(IsExporting ? L["Preparing Export..."] : L["Export JSON Backup"])
                        </AppButton>
                    </div>
                </div>

                <div class="soft-block p-5">
                    <p class="text-sm font-semibold text-text">@L["Import backup"]</p>
                    <p class="mt-2 text-sm leading-7 text-muted">@L["Importing a backup will replace your current library and settings after confirmation."]</p>
                    <div class="mt-4 flex flex-wrap items-center gap-3">
                        <label class="app-button app-button-secondary app-button-md cursor-pointer">
                            <InputFile OnChange="HandleImportSelectedAsync"
                                       accept=".json,application/json"
                                       class="sr-only" />
                            @L["Choose Backup File"]
                        </label>
                        @if (!string.IsNullOrWhiteSpace(SelectedImportFileName))
                        {
                            <span class="text-sm text-muted">@SelectedImportFileName</span>
                        }
                    </div>
                </div>

                <div class="space-y-4 text-sm leading-7 text-muted">
                    <p><span class="font-semibold text-text">@L["Tip:"]</span> @L["Save a backup before clearing data or moving to another device."]</p>
                    <p><span class="font-semibold text-text">@L["Import:"]</span> @L["Choose a WatchAtlas backup file in JSON format."]</p>
                    <p><span class="font-semibold text-text">@L["Restore:"]</span> @L["Restoring a backup replaces your current library and settings."]</p>
                </div>
            </div>
        </AppCard>
    </section>

    <AppCard Variant="strong">
        <div class="space-y-5">
            <SectionHeader Eyebrow="@L["Danger Zone"]"
                           Title="@L["Reset app data on this device"]"
                           Description="@L["This removes your library and saved preferences from this device."]" />

            <div class="flex flex-wrap items-center justify-between gap-4 rounded-3xl border border-red-200/70 bg-red-50/70 p-5 dark:border-red-400/20 dark:bg-red-500/10">
                <div class="space-y-2">
                    <p class="text-sm font-semibold text-red-700 dark:text-red-200">@L["Clear library and preferences"]</p>
                    <p class="text-sm leading-7 text-red-700/80 dark:text-red-100/80">@L["Use this if you want to remove everything from this device and start over."]</p>
                </div>

                <AppButton Disabled="@IsResetting" OnClick="OpenResetModalAsync">@L["Reset All Local Data"]</AppButton>
            </div>
        </div>
    </AppCard>

    <AppModal IsOpen="@IsImportModalOpen"
              Title="@L["Replace your current library with this backup?"]"
              Description="@L["This will replace your current library and settings. Export a backup first if you want an extra copy."]"
              OnClose="CloseImportModalAsync">
        <ChildContent>
            <div class="space-y-4 text-sm leading-7 text-muted">
                <p>@L.Format("This backup includes {0} item(s) and settings from {1}.", PendingImportBackup?.Library.MediaItems.Count ?? 0, SelectedImportFileName ?? L["the selected file"])</p>
                <p>@L["Your current library, filters, theme, and settings will be replaced after confirmation."]</p>
            </div>
        </ChildContent>
        <Footer>
                <AppButton Variant="secondary" Disabled="@IsImporting" OnClick="CloseImportModalButtonAsync">@L["Cancel"]</AppButton>
                <AppButton IsLoading="@IsImporting" OnClick="ConfirmImportAsync">@L["Replace Local Data"]</AppButton>
        </Footer>
    </AppModal>

    <AppModal IsOpen="@IsResetModalOpen"
              Title="@L["Clear all app data on this device?"]"
              Description="@L["This permanently removes your library and saved preferences from this device."]"
              OnClose="CloseResetModalAsync">
        <ChildContent>
            <p class="text-sm leading-7 text-muted">
                @L["All movies, shows, seasons, episodes, covers, filters, and preferences will be removed from this device."]
            </p>
        </ChildContent>
        <Footer>
            <AppButton Variant="secondary" Disabled="@IsResetting" OnClick="CloseResetModalButtonAsync">@L["Cancel"]</AppButton>
            <AppButton IsLoading="@IsResetting" OnClick="ConfirmResetAsync">@L["Reset Everything"]</AppButton>
        </Footer>
    </AppModal>
</section>

@code {
    private string? ErrorMessage { get; set; }
    private string? SelectedImportFileName { get; set; }
    private LibraryBackupModel? PendingImportBackup { get; set; }
    private bool IsExporting { get; set; }
    private bool IsImporting { get; set; }
    private bool IsResetting { get; set; }
    private bool IsImportModalOpen { get; set; }
    private bool IsResetModalOpen { get; set; }

    private IReadOnlyList<SortDropdown.SortDropdownOption> SortOptions => LibrarySortOptionHelper.Options
        .Select(option => new SortDropdown.SortDropdownOption
        {
            Key = option.Key,
            Label = L[option.Label]
        })
        .ToList();

    private string SelectedDefaultSortKey => LibrarySortOptionHelper.ToKey(
        SettingsState.Current.DefaultLibrarySortBy,
        SettingsState.Current.DefaultLibrarySortDescending);
    private AppLanguage SelectedLanguage => SettingsState.Current.Language ?? L.CurrentLanguage;

    protected override async Task OnInitializedAsync()
    {
        SettingsState.Changed += HandleStateChanged;
        await SettingsState.EnsureLoadedAsync();
        await LibraryState.EnsureLoadedAsync();
    }

    private Task HandleViewModeChanged(LibraryViewMode mode)
        => SettingsState.UpdateLibraryViewModeAsync(mode);

    private async Task HandleLanguageChanged(AppLanguage language)
    {
        await L.SetLanguageAsync(language);
    }

    private Task HandleDefaultSortChanged(string value)
    {
        var option = LibrarySortOptionHelper.Parse(value);
        return SettingsState.UpdateDefaultSortAsync(option.SortBy, option.Descending);
    }

    private async Task ExportBackupAsync(MouseEventArgs _)
    {
        try
        {
            IsExporting = true;
            ClearMessages();

            var backup = new LibraryBackupModel
            {
                BackupVersion = LibraryBackupModel.CurrentBackupVersion,
                ExportedAtUtc = DateTime.UtcNow,
                Library = await LibraryState.ExportStorageAsync(),
                Settings = LibraryCloneHelper.Clone(SettingsState.Current)
            };

            var fileName = $"watchatlas-backup-{DateTime.Now:yyyyMMdd-HHmmss}.json";
            var json = ImportExportService.Export(backup);
            await JsRuntime.InvokeVoidAsync("watchAtlasStorage.downloadTextFile", fileName, json, "application/json;charset=utf-8");
            ToastState.ShowSuccess(L["Backup exported."], L["A backup of your library and settings has been downloaded."]);
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
            ToastState.ShowError(L["Backup export failed."], exception.Message);
        }
        finally
        {
            IsExporting = false;
        }
    }

    private async Task HandleImportSelectedAsync(InputFileChangeEventArgs args)
    {
        ClearMessages();
        PendingImportBackup = null;
        IsImportModalOpen = false;

        var file = args.File;
        if (file is null)
        {
            SelectedImportFileName = null;
            return;
        }

        SelectedImportFileName = file.Name;

        try
        {
            await using var stream = file.OpenReadStream(10 * 1024 * 1024);
            using var reader = new StreamReader(stream);
            var json = await reader.ReadToEndAsync();
            var result = ImportExportService.Import(json);

            if (!result.IsSuccessful)
            {
                ErrorMessage = result.ErrorMessage ?? L["The selected backup could not be imported."];
                ToastState.ShowError(L["Import failed."], ErrorMessage);
                return;
            }

            PendingImportBackup = result.Backup;
            IsImportModalOpen = true;
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
            ToastState.ShowError(L["Import failed."], exception.Message);
        }
    }

    private Task OpenResetModalAsync(MouseEventArgs _)
    {
        ClearMessages();
        IsResetModalOpen = true;
        return Task.CompletedTask;
    }

    private Task CloseImportModalButtonAsync(MouseEventArgs _)
        => CloseImportModalAsync();

    private Task CloseImportModalAsync()
    {
        IsImportModalOpen = false;
        return Task.CompletedTask;
    }

    private Task CloseResetModalButtonAsync(MouseEventArgs _)
        => CloseResetModalAsync();

    private Task CloseResetModalAsync()
    {
        IsResetModalOpen = false;
        return Task.CompletedTask;
    }

    private async Task ConfirmImportAsync(MouseEventArgs _)
    {
        if (PendingImportBackup is null)
        {
            return;
        }

        try
        {
            IsImporting = true;
            ClearMessages();

            await LibraryState.ReplaceFromStorageAsync(PendingImportBackup.Library);
            await SettingsState.ReplaceAsync(PendingImportBackup.Settings);
            await L.SetLanguageAsync(PendingImportBackup.Settings.Language ?? L.CurrentLanguage);
            await ThemeState.ApplyThemeAsync(PendingImportBackup.Settings.ThemeMode);
            FilterState.Reset(SettingsState.Current.DefaultLibrarySortBy, SettingsState.Current.DefaultLibrarySortDescending);

            ToastState.ShowSuccess(L["Backup restored."], L["The selected backup replaced your current library and settings."]);
            IsImportModalOpen = false;
            SelectedImportFileName = null;
            PendingImportBackup = null;
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
            ToastState.ShowError(L["Backup restore failed."], exception.Message);
        }
        finally
        {
            IsImporting = false;
        }
    }

    private async Task ConfirmResetAsync(MouseEventArgs _)
    {
        try
        {
            IsResetting = true;
            ClearMessages();

            await LibraryState.ResetAsync();
            await SettingsState.ResetAsync();
            await L.RefreshFromSettingsAsync();
            await ThemeState.ApplyThemeAsync(SettingsState.Current.ThemeMode);
            FilterState.Reset(SettingsState.Current.DefaultLibrarySortBy, SettingsState.Current.DefaultLibrarySortDescending);

            ToastState.ShowSuccess(L["Local data reset."], L["Your library and saved preferences were removed from this device."]);
            IsResetModalOpen = false;
            SelectedImportFileName = null;
            PendingImportBackup = null;
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
            ToastState.ShowError(L["Reset failed."], exception.Message);
        }
        finally
        {
            IsResetting = false;
        }
    }

    private void ClearMessages()
    {
        ErrorMessage = null;
    }

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        SettingsState.Changed -= HandleStateChanged;
    }
}
