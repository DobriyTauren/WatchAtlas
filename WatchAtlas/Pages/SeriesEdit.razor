@page "/series/{Id:guid}/edit"
@inject LibraryState LibraryState
@inject NavigationManager NavigationManager
@inject ToastState ToastState

<PageTitle>@L["Edit Series"]</PageTitle>

<section class="space-y-8">
    @if (!IsReady)
    {
        <PageHeader Eyebrow="@L["Series Editor"]"
                    Title="@L["Loading series editor."]"
                    Subtitle="@L["Getting this series ready to edit."]" />
    }
    else if (Entry is null)
    {
        <PageHeader Eyebrow="@L["Series Editor"]"
                    Title="@L["This series could not be found."]"
                    Subtitle="@L["It may have been removed, or the link may be out of date."]" />

        <EmptyStateCard Badge="@L["Series Editor"]"
                        Title="@L["Series not found."]"
                        Description="@L["Create a series first or return to the library to pick an existing entry."]"
                        PrimaryLabel="@L["Create Series"]"
                        PrimaryHref="series/new"
                        SecondaryLabel="@L["Open Library"]"
                        SecondaryHref="library" />
    }
    else
    {
        <PageHeader Eyebrow="@L["Edit Show"]"
                    Title="@Entry.Media.Title"
                    Subtitle="@L["Update the show details, seasons, and episodes."]" />

        <section class="grid gap-4 xl:grid-cols-[1.15fr,0.85fr]">
            <AppCard>
                <SeriesForm Model="Form"
                            SubmitLabel="@L["Save Changes"]"
                            CancelHref="@($"series/{Id}")"
                            FieldPrefix="series-edit"
                            ExternalErrorMessage="@ErrorMessage"
                            IsBusy="IsSaving"
                            OnSubmitRequested="SaveAsync" />
            </AppCard>

            <AppCard>
                <div class="space-y-5">
                    <div class="flex flex-wrap gap-2">
                        <AppBadge>@L["Show"]</AppBadge>
                        @if (Entry.Media.PersonalRating is { } rating)
                        {
                            <span class="rating-pill">@rating/10</span>
                        }
                    </div>

                    <div class="grid gap-4 sm:grid-cols-2">
                        <div class="soft-block-strong p-5">
                            <p class="text-sm font-semibold text-text">@L["Created"]</p>
                            <p class="mt-2 text-lg">@Entry.Media.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</p>
                        </div>

                        <div class="soft-block-strong p-5">
                            <p class="text-sm font-semibold text-text">@L["Updated"]</p>
                            <p class="mt-2 text-lg">@Entry.Media.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy")</p>
                        </div>
                    </div>

                    <div class="flex flex-wrap gap-3">
                        <AppButton Href="@($"series/{Id}")" Variant="secondary">@L["Back to Details"]</AppButton>
                        <AppButton Href="library" Variant="secondary">@L["Open Library"]</AppButton>
                    </div>
                </div>
            </AppCard>
        </section>
    }
</section>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private LibraryEntry? Entry { get; set; }
    private SeriesFormModel Form { get; set; } = new();
    private bool IsReady { get; set; }
    private bool IsSaving { get; set; }
    private string? ErrorMessage { get; set; }
    protected override async Task OnParametersSetAsync()
    {
        IsReady = false;
        ErrorMessage = null;

        await LibraryState.EnsureLoadedAsync();
        var entry = LibraryState.GetById(Id);
        Entry = entry?.Media.Type == MediaType.Series ? entry : null;

        if (Entry is not null)
        {
            Form = SeriesFormModel.From(Entry.Media, Entry.Series);
        }

        IsReady = true;
    }

    private async Task SaveAsync()
    {
        if (Entry is null)
        {
            return;
        }

        var media = LibraryCloneHelper.Clone(Entry.Media);
        var series = LibraryCloneHelper.Clone(Entry.Series) ?? new SeriesDetails
        {
            MediaItemId = Entry.Media.Id
        };

        Form.ApplyTo(media, series);

        try
        {
            IsSaving = true;
            ErrorMessage = null;

            await LibraryState.UpdateAsync(media, null, series);
            var refreshedEntry = LibraryState.GetById(Id);
            Entry = refreshedEntry?.Media.Type == MediaType.Series ? refreshedEntry : null;

            if (Entry is not null)
            {
                Form = SeriesFormModel.From(Entry.Media, Entry.Series);
                ToastState.ShowSuccess(L["Show saved."], L["Your show details were updated successfully."]);
            }
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
            ToastState.ShowError(L["Show changes could not be saved."], exception.Message);
        }
        finally
        {
            IsSaving = false;
        }
    }
}
