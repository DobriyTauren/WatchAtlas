@page "/series/{Id:guid}"
@inject LibraryState LibraryState
@inject IStatisticsService StatisticsService
@inject NavigationManager NavigationManager
@inject ToastState ToastState

<PageTitle>@L["Show Details"]</PageTitle>

<section class="space-y-8">
    @if (!IsReady)
    {
        <PageHeader Eyebrow="@L["Show Details"]"
                    Title="@L["Loading show details."]"
                    Subtitle="@L["Reading the selected show from browser storage."]" />
    }
    else if (Entry is null)
    {
        <PageHeader Eyebrow="@L["Show Details"]"
                    Title="@L["This show is not in the library yet."]"
                    Subtitle="@L["The details route is ready, but the requested show was not found in browser storage."]" />

        <EmptyStateCard Badge="@L["Show Details"]"
                        Title="@L["No shows found."]"
                        Description="@L["Create a show first, then return here to review seasons, episodes, and progress."]"
                        PrimaryLabel="@L["Create Show"]"
                        PrimaryHref="series/new"
                        SecondaryLabel="@L["Return to Library"]"
                        SecondaryHref="library" />
    }
    else
    {
        <PageHeader Eyebrow="@L["Show Details"]"
                    Title="@Entry.Media.Title"
                    Subtitle="@GetSubtitle()"
                    Actions="@ActionButtons" />

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="soft-block-strong border border-red-200/70 p-4 text-sm text-red-700">
                @ErrorMessage
            </div>
        }

        <section class="grid gap-4 xl:grid-cols-[0.95fr,1.15fr]">
            <AppCard Class="self-start">
                <div class="mx-auto aspect-[2/3] w-full max-w-[22rem] overflow-hidden rounded-[1.75rem] border border-border/70 bg-surface-soft/60">
                    @if (!string.IsNullOrWhiteSpace(Entry.Media.CoverImageUrl))
                    {
                        <img src="@Entry.Media.CoverImageUrl"
                             alt="@($"{Entry.Media.Title} cover")"
                             class="h-full w-full object-cover" />
                    }
                    else
                    {
                        <div class="movie-cover-fallback h-full">
                            <span class="movie-cover-fallback__badge">@L["Show"]</span>
                            <h2 class="movie-cover-fallback__title">@Entry.Media.Title</h2>
                            <p class="movie-cover-fallback__copy">@L["Add a cover image from the edit page to give the show page a stronger visual identity."]</p>
                        </div>
                    }
                </div>
            </AppCard>

            <div class="space-y-4">
                <AppCard>
                    <div class="space-y-5">
                        <div class="flex flex-wrap gap-2">
                            <MediaTypeBadge Type="@MediaType.Series" />
                            <MediaStatusBadge Status="@WatchStatusHelper.GetStatus(Entry)" />
                            @if (Entry.Media.PersonalRating is { } rating)
                            {
                                <span class="rating-pill">@rating/10</span>
                            }
                        </div>

                        <ProgressBar Label="@L["Show Completion"]"
                                     Value="@SeriesStats.CompletionPercent"
                                     Max="100" />

                        @if (Entry.Media.Genres.Count > 0)
                        {
                            <div class="flex flex-wrap gap-2">
                                @foreach (var genre in Entry.Media.Genres)
                                {
                                    <AppBadge Variant="outline">@genre</AppBadge>
                                }
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(Entry.Series?.Universe))
                        {
                            <div class="soft-block p-4">
                                <p class="text-sm font-semibold text-text">@L["Universe"]</p>
                                <p class="mt-2 text-sm text-muted">@Entry.Series.Universe</p>
                            </div>
                        }

                        <div class="grid gap-4 sm:grid-cols-2">
                            <div class="soft-block p-5">
                                <p class="text-sm font-semibold text-text">@L["Episodes"]</p>
                                <p class="mt-2 text-lg">@L.Format("{0} / {1} watched", SeriesStats.WatchedEpisodes, SeriesStats.TotalEpisodes)</p>
                            </div>

                            <div class="soft-block p-5">
                                <p class="text-sm font-semibold text-text">@L["Watch Time"]</p>
                                <p class="mt-2 text-lg">@SeriesStats.WatchedMinutes.ToReadableDuration()</p>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Entry.Media.Description))
                        {
                            <div class="space-y-2">
                                <h2 class="text-xl">@L["Summary"]</h2>
                                <p class="text-sm leading-7 text-muted">@Entry.Media.Description</p>
                            </div>
                        }
                    </div>
                </AppCard>

                <section class="grid gap-4 sm:grid-cols-2">
                    <StatTile Title="@L["Seasons"]" Value="@SeriesStats.SeasonCount.ToString()" Caption="@L["Tracked in this show."]" ChipLabel="@L["Show"]" />
                    <StatTile Title="@L["Episodes"]" Value="@SeriesStats.TotalEpisodes.ToString()" Caption="@L["Total episodes tracked."]" ChipLabel="@L["Episodes"]" />
                    <StatTile Title="@L["Watched"]" Value="@SeriesStats.WatchedEpisodes.ToString()" Caption="@L["Marked as watched."]" ChipLabel="@L["Progress"]" />
                    <StatTile Title="@L["Runtime"]" Value="@SeriesStats.WatchedMinutes.ToReadableDuration()" Caption="@L["Watched episode time."]" ChipLabel="@L["Runtime"]" />
                </section>
            </div>
        </section>

        <AppCard>
            <div class="space-y-5">
                <div class="flex flex-wrap items-center justify-between gap-3">
                    <div>
                        <h2 class="text-2xl">@L["Season Breakdown"]</h2>
                        <p class="mt-2 text-sm leading-7 text-muted">@L["Open each season to inspect episode progress, runtime, and watched dates."]</p>
                    </div>

                    <div class="flex flex-wrap gap-3">
                        <AppButton Href="@($"series/{Id}/edit")" Variant="secondary">@L["Quick Edit"]</AppButton>
                        <AppButton Href="library" Variant="secondary">@L["Open Library"]</AppButton>
                    </div>
                </div>

                @if (SeriesStats.Seasons.Count == 0)
                {
                    <div class="soft-block p-5 text-sm text-muted">
                        @L["No seasons have been added yet. Open the editor to create the first season and generate episodes."]
                    </div>
                }
                else
                {
                    @foreach (var seasonStats in SeriesStats.Seasons)
                    {
                        var season = Entry.Series?.Seasons.FirstOrDefault(item => item.Id == seasonStats.SeasonId);

                        <details class="series-accordion">
                            <summary class="series-accordion__summary">
                                <div class="space-y-2">
                                    <div class="flex flex-wrap items-center gap-2">
                                        <h3 class="text-xl">@L.Format("Season {0}", seasonStats.SeasonNumber)</h3>
                                        <SeriesStatusBadge Statistics="seasonStats" />
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(seasonStats.Title))
                                    {
                                        <p class="text-sm text-muted">@seasonStats.Title</p>
                                    }
                                </div>

                                <div class="series-accordion__meta">
                                    <span>@L.Format("{0} / {1} watched", seasonStats.WatchedEpisodes, seasonStats.TotalEpisodes)</span>
                                    <span>@seasonStats.WatchedMinutes.ToReadableDuration()</span>
                                </div>
                            </summary>

                            <div class="space-y-4 pt-4">
                                <ProgressBar Label="@L["Season Completion"]"
                                             Value="@seasonStats.CompletionPercent"
                                             Max="100" />

                                @if (season?.Episodes.Count > 0)
                                {
                                    <div class="space-y-3">
                                        @foreach (var episode in season.Episodes.OrderBy(item => item.EpisodeNumber))
                                        {
                                            <article class="soft-block flex flex-col gap-3 p-4 lg:flex-row lg:items-center lg:justify-between">
                                                <div class="space-y-1">
                                                    <div class="flex flex-wrap items-center gap-2">
                                                        <p class="font-semibold text-text">@L.Format("Episode {0}", episode.EpisodeNumber)</p>
                                                        <AppBadge Variant="@GetEpisodeBadgeVariant(episode)">@GetEpisodeBadgeLabel(episode)</AppBadge>
                                                    </div>

                                                    @if (!string.IsNullOrWhiteSpace(episode.Title))
                                                    {
                                                        <p class="text-sm text-muted">@episode.Title</p>
                                                    }
                                                </div>

                                                <div class="flex flex-wrap gap-4 text-sm text-muted">
                                                    <span>@((episode.DurationMinutes ?? 0).ToReadableDuration())</span>
                                                    <span>@(episode.WatchedDate?.ToLocalTime().ToString("dd MMM yyyy") ?? L["No watch date"])</span>
                                                </div>
                                            </article>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="soft-block p-4 text-sm text-muted">@L["This season does not contain any episodes yet."]</div>
                                }
                            </div>
                        </details>
                    }
                }
            </div>
        </AppCard>

        <AppModal IsOpen="@IsDeleteModalOpen"
                  Title="@L["Delete this show?"]"
                  Description="@L["This permanently removes the show and all stored seasons and episodes from browser storage."]"
                  OnClose="CloseDeleteModalAsync">
            <ChildContent>
                <p class="text-sm leading-7 text-muted">
                    @L.Format("\"{0}\" and all tracked episode progress will be removed from the library immediately.", Entry.Media.Title)
                </p>
            </ChildContent>
            <Footer>
                <AppButton Variant="secondary" Disabled="@IsDeleting" OnClick="CloseDeleteModalButtonAsync">@L["Cancel"]</AppButton>
                <AppButton IsLoading="@IsDeleting" OnClick="ConfirmDeleteAsync">@L["Delete Show"]</AppButton>
            </Footer>
        </AppModal>
    }
</section>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private LibraryEntry? Entry { get; set; }
    private SeriesStatistics SeriesStats { get; set; } = new();
    private bool IsReady { get; set; }
    private bool IsDeleteModalOpen { get; set; }
    private bool IsDeleting { get; set; }
    private string? ErrorMessage { get; set; }

    private RenderFragment ActionButtons => @<div class="flex flex-wrap gap-3">
        <AppButton Href="@($"series/{Id}/edit")" Variant="secondary">@L["Edit Show"]</AppButton>
        <AppButton OnClick="OpenDeleteModalAsync">@L["Delete Show"]</AppButton>
    </div>;

    protected override async Task OnParametersSetAsync()
    {
        IsReady = false;
        ErrorMessage = null;
        IsDeleteModalOpen = false;

        await LibraryState.EnsureLoadedAsync();
        var entry = LibraryState.GetById(Id);
        Entry = entry?.Media.Type == MediaType.Series ? entry : null;
        SeriesStats = Entry is null ? new SeriesStatistics() : StatisticsService.CalculateSeriesStatistics(Entry);
        IsReady = true;
    }

    private string GetSubtitle()
    {
        if (Entry is null)
        {
            return string.Empty;
        }

        return SeriesStats.TotalEpisodes == 0
            ? L["This show is saved and ready for seasons, episodes, and watch tracking."]
            : L["Progress, watched runtime, and per-season completion are calculated automatically from episode state."];
    }

    private static string GetEpisodeBadgeVariant(Episode episode)
        => episode.IsWatched ? "success" : "muted";

    private static string GetEpisodeBadgeLabel(Episode episode)
        => episode.IsWatched ? LocalizedText.Translate("Watched") : LocalizedText.Translate("Pending");

    private string UniverseLabel
        => LocalizedText.GetCurrentLanguage() == AppLanguage.Russian
            ? "Вселенная"
            : "Universe";

    private Task OpenDeleteModalAsync(MouseEventArgs _)
    {
        IsDeleteModalOpen = true;
        return Task.CompletedTask;
    }

    private Task CloseDeleteModalButtonAsync(MouseEventArgs _)
        => CloseDeleteModalAsync();

    private Task CloseDeleteModalAsync()
    {
        IsDeleteModalOpen = false;
        return Task.CompletedTask;
    }

    private async Task ConfirmDeleteAsync(MouseEventArgs _)
    {
        if (Entry is null)
        {
            return;
        }

        var deletedTitle = Entry.Media.Title;

        try
        {
            IsDeleting = true;
            ErrorMessage = null;
            await LibraryState.DeleteAsync(Entry.Media.Id);
            ToastState.ShowSuccess(L["Show deleted."], L.Format("\"{0}\" and its tracked progress were removed.", deletedTitle));
            NavigationManager.NavigateTo("library");
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
            ToastState.ShowError(L["Show could not be deleted."], exception.Message);
        }
        finally
        {
            IsDeleting = false;
            IsDeleteModalOpen = false;
        }
    }
}
