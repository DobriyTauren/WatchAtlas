@page "/"

@implements IDisposable
@inject LibraryState LibraryState
@inject IStatisticsService StatisticsService
@using WatchAtlas.Extensions

<PageTitle>WatchAtlas</PageTitle>

<section class="space-y-8">
    @if (LibraryState.IsLoading && !LibraryState.IsLoaded)
    {
        <PageHeader Eyebrow="Overview"
                    Title="Loading your watch library."
                    Subtitle="Getting your movies, series, and watch progress ready." />

        <section class="grid gap-4 xl:grid-cols-[1.4fr,1fr]">
            <AppCard Class="space-y-6">
                <SkeletonBlock HeightClass="h-7" Class="w-36" />
                <SkeletonBlock HeightClass="h-12" Class="w-full max-w-2xl" />
                <SkeletonBlock HeightClass="h-4" Class="w-full" />
                <SkeletonBlock HeightClass="h-4" Class="w-5/6" />
                <div class="grid gap-4 sm:grid-cols-2">
                    <SkeletonCard ShowChip="false" />
                    <SkeletonCard ShowChip="false" />
                </div>
            </AppCard>

            <SkeletonCard Class="h-full" />
        </section>

        <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <SkeletonCard />
            <SkeletonCard />
            <SkeletonCard />
            <SkeletonCard />
        </section>
    }
    else
    {
        <PageHeader Eyebrow="Overview"
                    Title="Your personal watch library starts here."
                    Subtitle="Track what you've watched, see your progress, and jump back into your library anytime.">
        </PageHeader>

        <section class="shell-card overflow-hidden p-6 sm:p-8">
            <div class="space-y-4">
                <span class="section-chip">Welcome</span>
                <h2 class="max-w-2xl text-3xl">A soft, simple place to keep up with what you've watched.</h2>
                <p class="max-w-3xl text-sm leading-7 text-muted sm:text-base">
                    Add films and series, follow episode progress, and keep an eye on your total watch time without losing the calm feel of a personal collection.
                </p>
            </div>
        </section>

        <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <StatTile Title="Watched Movies" Value="@Stats.WatchedMovies.ToString()" Caption="Movies you've already marked as watched." ChipLabel="Movies" />
            <StatTile Title="Series Added" Value="@Stats.TotalSeries.ToString()" Caption="Series currently in your library." ChipLabel="Series" />
            <StatTile Title="Watched Episodes" Value="@Stats.WatchedEpisodes.ToString()" Caption="Episodes you've checked off so far." ChipLabel="Episodes" />
            <StatTile Title="Watch Time" Value="@Stats.TotalWatchTimeMinutes.ToReadableDuration()" Caption="Time you've spent watching across the library." ChipLabel="Runtime" />
        </section>
    }
</section>

@code {
    private GlobalStatistics Stats => StatisticsService.CalculateGlobalStatistics(LibraryState.Entries);

    protected override async Task OnInitializedAsync()
    {
        LibraryState.Changed += HandleLibraryChanged;
        await LibraryState.EnsureLoadedAsync();
    }

    private void HandleLibraryChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        LibraryState.Changed -= HandleLibraryChanged;
    }
}
