@page "/media/{Id}"
@inject LibraryState LibraryState
@inject IStatisticsService StatisticsService
@using WatchAtlas.Extensions

<PageTitle>Media Details</PageTitle>

<section class="space-y-8">
    @if (Entry is null)
    {
        <PageHeader Eyebrow="Media Details"
                    Title="This entry is not in the library yet."
                    Subtitle="The route is already in place for detail pages, but your repository is currently empty. Once CRUD lands, this page can read straight from the shared library state." />

        <EmptyStateCard Badge="Details"
                        Title="No media entry found."
                        Description="Try creating a new item first, then this route can become the home for cover art, notes, seasons, and episode progress."
                        PrimaryLabel="Create New Item"
                        PrimaryHref="/media/new"
                        SecondaryLabel="Return to Library"
                        SecondaryHref="/library" />
    }
    else
    {
        <PageHeader Eyebrow="Media Details"
                    Title="@Entry.Media.Title"
                    Subtitle="@Entry.Media.Description" />

        <section class="grid gap-4 xl:grid-cols-[1.2fr,0.9fr]">
            <article class="shell-card p-6 sm:p-8">
                <div class="space-y-5">
                    <div class="flex flex-wrap gap-2">
                        <span class="tag-pill">@(Entry.Media.Type == MediaType.Movie ? "Movie" : "Series")</span>
                        <span class="rounded-full bg-white/60 px-3 py-1 text-xs font-semibold text-muted">
                            Rating: @(Entry.Media.PersonalRating?.ToString() ?? "Not set")
                        </span>
                    </div>

                    <div class="grid gap-4 sm:grid-cols-2">
                        <div class="rounded-[1.75rem] bg-white/45 p-5">
                            <p class="text-sm font-semibold text-text">Last Updated</p>
                            <p class="mt-2 text-lg">@Entry.Media.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy")</p>
                        </div>

                        <div class="rounded-[1.75rem] bg-white/45 p-5">
                            <p class="text-sm font-semibold text-text">Tracked Time</p>
                            <p class="mt-2 text-lg">@GetRuntimeSummary()</p>
                        </div>
                    </div>
                </div>
            </article>

            <article class="shell-card p-6 sm:p-8">
                <div class="space-y-4">
                    <h2 class="text-2xl">Detail View Next Steps</h2>
                    <div class="space-y-4 text-sm leading-7 text-muted">
                        <p>Display cover art, genre tags, notes, and edit actions.</p>
                        <p>Show season breakdown, episode list, and watch progress for series.</p>
                        <p>Connect edit and delete flows through the repository abstraction.</p>
                    </div>
                </div>
            </article>
        </section>
    }
</section>

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private LibraryEntry? Entry { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await LibraryState.EnsureLoadedAsync();
        Entry = Guid.TryParse(Id, out var parsedId) ? LibraryState.GetById(parsedId) : null;
    }

    private string GetRuntimeSummary()
    {
        if (Entry is null)
        {
            return "Not available";
        }

        if (Entry.Media.Type == MediaType.Movie)
        {
            return (Entry.Movie?.DurationMinutes ?? 0).ToReadableDuration();
        }

        return StatisticsService.CalculateSeriesProgress(Entry).WatchedMinutes.ToReadableDuration();
    }
}
