@page "/media/{Id}"
@inject LibraryState LibraryState
@inject IStatisticsService StatisticsService
@inject NavigationManager NavigationManager
@using WatchAtlas.Extensions

<PageTitle>@L["Media Details"]</PageTitle>

<section class="space-y-8">
    @if (Media is null)
    {
        <PageHeader Eyebrow="@L["Media Details"]"
                    Title="@L["We couldn't find this item in your library."]"
                    Subtitle="@L["Create it first, then come back here to edit it."]" />

        <EmptyStateCard Badge="@L["Details"]"
                        Title="@L["No media entry found."]"
                        Description="@L["Create an item first, then come back here to edit details and track progress."]"
                        PrimaryLabel="@L["Create New Item"]"
                        PrimaryHref="media/new"
                        SecondaryLabel="@L["Return to Library"]"
                        SecondaryHref="library" />
    }
    else
    {
        <PageHeader Eyebrow="@L["Media Details"]"
                    Title="@Media.Title"
                    Subtitle="@L["Edit this item and update its details and progress."]" />

        <section class="grid gap-4 xl:grid-cols-[1.2fr,0.9fr]">
            <AppCard>
                <MediaEditorForm Media="Media"
                                 MovieDetails="Movie"
                                 SeriesDetails="Series"
                                 SubmitLabel="@L["Save Changes"]"
                                 DeleteLabel="@L["Delete Entry"]"
                                 CancelHref="library"
                                 FieldPrefix="media-details"
                                 AllowDelete="true"
                                 ExternalErrorMessage="@ErrorMessage"
                                 IsBusy="IsSaving"
                                 OnSubmitRequested="SaveAsync"
                                 OnDeleteRequested="DeleteAsync" />
            </AppCard>

            <AppCard>
                @if (PreviewEntry is not null)
                {
                    <div class="space-y-5">
                        <div class="flex flex-wrap gap-2">
                            <AppBadge>@(PreviewEntry.Media.Type == MediaType.Movie ? L["Movie"] : L["Show"])</AppBadge>
                            <span class="rating-pill">
                                @L.Format("Rating: {0}", PreviewEntry.Media.PersonalRating?.ToString() ?? L["Not set"])
                            </span>
                        </div>

                        <div class="grid gap-4 sm:grid-cols-2">
                            <div class="soft-block-strong p-5">
                                <p class="text-sm font-semibold text-text">@L["Last Updated"]</p>
                                <p class="mt-2 text-lg">@Media.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy")</p>
                            </div>

                            <div class="soft-block-strong p-5">
                                <p class="text-sm font-semibold text-text">@L["Tracked Time"]</p>
                                <p class="mt-2 text-lg">@GetRuntimeSummary()</p>
                            </div>
                        </div>

                        <div class="space-y-4 text-sm leading-7 text-muted">
                            @if (PreviewEntry.Media.Type == MediaType.Series)
                            {
                                var seriesStats = StatisticsService.CalculateSeriesStatistics(PreviewEntry);

                                <ProgressBar Label="@L["Completion"]"
                                             Value="@seriesStats.WatchedEpisodes"
                                             Max="@Math.Max(seriesStats.TotalEpisodes, 1)" />
                                <p>@L.Format("{0} season(s), {1} tracked episode(s), {2} watched.", seriesStats.SeasonCount, seriesStats.TotalEpisodes, seriesStats.WatchedEpisodes)</p>
                                <p>@L.Format("{0}% complete with {1} of watched runtime.", seriesStats.CompletionPercent.ToString("0"), seriesStats.WatchedMinutes.ToReadableDuration())</p>
                            }
                            else
                            {
                                <p>@(PreviewEntry.Movie?.IsWatched == true ? L["This movie is marked as watched."] : L["This movie is still marked as not watched."])</p>
                                <p>@L.Format("Stored runtime: {0}.", (PreviewEntry.Movie?.DurationMinutes ?? 0).ToReadableDuration())</p>
                            }
                        </div>
                    </div>
                }
            </AppCard>
        </section>
    }
</section>

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private MediaItem? Media { get; set; }
    private WatchAtlas.Models.MovieDetails Movie { get; set; } = new();
    private SeriesDetails Series { get; set; } = new();
    private bool IsSaving { get; set; }
    private string? ErrorMessage { get; set; }
    private LibraryEntry? PreviewEntry => Media is null ? null : LibraryEntryFactory.Create(Media, Movie, Series);

    protected override async Task OnParametersSetAsync()
    {
        await LibraryState.EnsureLoadedAsync();

        if (Guid.TryParse(Id, out var parsedId))
        {
            var entry = LibraryState.GetById(parsedId);
            if (entry is not null)
            {
                NavigationManager.NavigateTo(MediaRouteHelper.GetDetailsHref(entry), replace: true);
                return;
            }

            LoadEditorState(entry);
            return;
        }

        Media = null;
    }

    private string GetRuntimeSummary()
    {
        if (PreviewEntry is null)
        {
            return L["Not available"];
        }

        if (PreviewEntry.Media.Type == MediaType.Movie)
        {
            return (PreviewEntry.Movie?.DurationMinutes ?? 0).ToReadableDuration();
        }

        return StatisticsService.CalculateSeriesProgress(PreviewEntry).WatchedMinutes.ToReadableDuration();
    }

    private async Task SaveAsync()
    {
        if (Media is null)
        {
            return;
        }

        try
        {
            IsSaving = true;
            ErrorMessage = null;

            await LibraryState.UpdateAsync(Media, Movie, Series);
            LoadEditorState(LibraryState.GetById(Media.Id));
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
        finally
        {
            IsSaving = false;
        }
    }

    private async Task DeleteAsync()
    {
        if (Media is null)
        {
            return;
        }

        try
        {
            IsSaving = true;
            ErrorMessage = null;

            await LibraryState.DeleteAsync(Media.Id);
            NavigationManager.NavigateTo("library");
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
            IsSaving = false;
        }
    }

    private void LoadEditorState(LibraryEntry? entry)
    {
        ErrorMessage = null;
        IsSaving = false;

        if (entry is null)
        {
            Media = null;
            Movie = new WatchAtlas.Models.MovieDetails();
            Series = new SeriesDetails();
            return;
        }

        Media = LibraryCloneHelper.Clone(entry.Media);
        Movie = LibraryCloneHelper.Clone(entry.Movie) ?? new WatchAtlas.Models.MovieDetails
        {
            MediaItemId = entry.Media.Id
        };
        Series = LibraryCloneHelper.Clone(entry.Series) ?? new SeriesDetails
        {
            MediaItemId = entry.Media.Id
        };
    }
}
